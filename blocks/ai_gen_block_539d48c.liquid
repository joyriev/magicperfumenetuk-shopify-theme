    {
      "type": "color",
      "id": "product_title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Price color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Quick add button"
    },
    {
