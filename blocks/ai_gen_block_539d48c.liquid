      "label": "Hover background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "see_more_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "see_more_border_color",
      "label": "Border",
      "default": "#0f172a"
    },
    {
      "type": "range",
      "id": "see_more_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
