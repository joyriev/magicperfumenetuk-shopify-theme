<div
  x-data
  x-transition
  x-show="$store.bundleBuilder.showModal"
  class="fixed inset-0 bg-black bg-opacity-50 flex items-end md:items-center justify-center z-[9999]"
  x-cloak>
  <div class="bg-white rounded-lg px-3 pt-4 md:pt-6 pb-3 md:pb-6 md:px-6 max-w-2xl w-full h-[80vh] md:h-[90vh] flex flex-col relative" @click.away="$store.bundleBuilder.showModal = false">
    <button @click="$store.bundleBuilder.showModal = false" class="absolute -top-10 right-2 md:-top-2 md:-right-2 w-8 h-8 bg-white text-black rounded-full shadow flex items-center justify-center hover:bg-black hover:text-white border-0 text-3xl cursor-pointer transition">
      <span class="[rotate:-45deg] size-5 flex">
        {{- 'icon-plus.svg' | inline_asset_content -}}
      </span>
    </button>
    <div class="modal-header flex-shrink-0">
      <div>
        <h2 class="text-lg md:text-xl font-bold text-gray-900 mt-0 mb-2 md:mb-4 text-center tracking-normal" x-text="$store.bundleBuilder.selectedProducts.length === $store.bundleBuilder.bundleLength ? 'YOUR BUNDLE IS READY! 👑' : `ADD ${ $store.bundleBuilder.bundleLength - $store.bundleBuilder.selectedProducts.length} MORE SCENT${ $store.bundleBuilder.bundleLength - $store.bundleBuilder.selectedProducts.length > 1 ? 'S' : ''}`"></h2>
      </div>
      <div x-show="$store.bundleBuilder.selectedProducts.length < $store.bundleBuilder.bundleLength">
        <div class="grid grid-cols-3 gap-2">
          <button
            @click="$store.bundleBuilder.activeCategory = 'All'"
            :class="$store.bundleBuilder.activeCategory === 'All' ? 'bg-black text-white' : 'bg-white'"
            class="px-3 py-1 text-sm uppercase rounded border border-solid border-black cursor-pointer">Trending</button>
          <button
            @click="$store.bundleBuilder.activeCategory = 'fuer-maenner'"
            :class="$store.bundleBuilder.activeCategory === 'fuer-maenner' ? 'bg-black text-white' : 'bg-white'"
            class="px-3 py-1 text-sm uppercase rounded border border-solid border-black cursor-pointer">Men</button>
          <button
            @click="$store.bundleBuilder.activeCategory = 'fuer-frauen'"
            :class="$store.bundleBuilder.activeCategory === 'fuer-frauen' ? 'bg-black text-white' : 'bg-white'"
            class="px-3 py-1 text-sm uppercase rounded border border-solid border-black cursor-pointer">Women</button>
        </div>
      </div>
    </div>

    {% comment %} Product Grid {% endcomment %}
    <div class="flex-1 overflow-y-auto -mx-2 px-2">
      <template x-if="$store.bundleBuilder.selectedProducts.length === $store.bundleBuilder.bundleLength">
        <div class="text-center mt-10">
          <div role="status">
            <svg
              aria-hidden="true"
              class="size-20 text-gray-200 animate-spin fill-black"
              viewBox="0 0 100 101"
              fill="none"
              xmlns="http://www.w3.org/2000/svg">
              <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor" />
              <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill" />
            </svg>
            <span class="sr-only">Loading...</span>
          </div>
          <p class="font-semibold text-lg tracking-normal">Redirecting To Checkout...</p>
        </div>
      </template>
      <template x-if="$store.bundleBuilder.selectedProducts.length < $store.bundleBuilder.bundleLength">
        <div class="space-y-2">
          <template x-for="product in $store.bundleBuilder.availableProducts" :key="product.id">
            <template x-if="(product.tags.some(tag => tag === $store.bundleBuilder.activeCategory) || $store.bundleBuilder.activeCategory === 'All') &&
         ($store.bundleBuilder.searchText === '' || product.name.toLowerCase().includes($store.bundleBuilder.searchText.toLowerCase()))">
              <button
                @click="$store.bundleBuilder.addRemoveProduct(product)"
                :class="$store.bundleBuilder.isProductSelected(product.id) ? 'border-black border-2' : 'border-gray-200 border'"
                class="border-solid w-full p-2 flex items-center gap-2 justify-between cursor-pointer rounded-lg bg-white">
                <img
                  class="object-cover rounded"
                  :src="product.image"
                  :alt="product.name"
                  width="40"
                  height="40">
                <div class="text-left flex flex-col gap-1">
                  <div class="font-bold text-lg leading-tight text-black line-clamp-1" x-text="product.name"></div>
                </div>
                <div class="ml-auto" x-text="$store.bundleBuilder.selectedVariant"></div>
              </button>
            </template>
          </template>
        </div>
      </template>
    </div>
  </div>
</div>