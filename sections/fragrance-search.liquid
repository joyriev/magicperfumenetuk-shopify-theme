  function getSimilarFromMapping(product, excludeId) {
    const productTitle = product.title.toLowerCase();
    let similarProducts = [];
    
    // Check if product matches any known fragrance
    for (const [key, value] of Object.entries(similarFragrances)) {
      if (productTitle.includes(key)) {
        // Get products from the similar list
        value.similar.forEach(sim => {
          const found = hardcodedProducts.find(p => 
            p.number === sim.number && p.id !== excludeId
          );
          if (found) similarProducts.push(found);
        });
        break;
      }
    }
    
    return similarProducts;
  }

