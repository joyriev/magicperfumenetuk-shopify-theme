<script>
(function() {
  // ===== YOUR SHOPIFY PRODUCTS =====
  let fcProducts = [];
  let currentView = 'search';
  let currentSearchQuery = '';
  
  // Debounce timer
  let searchTimer = null;

  // Get elements
  const stickyButton = document.getElementById('fcStickyButton');
  const searchPopup = document.getElementById('fcSearchPopup');
  const searchInput = document.getElementById('fcSearchInput');
  const clearSearch = document.getElementById('fcClearSearch');
  const steps = document.getElementById('fcSteps');
  const content = document.getElementById('fcContent');
  
  // Offer elements
  const offerBanner = document.getElementById('fcOfferBanner');
  const offerStatus = document.getElementById('fcOfferStatus');
  const offerProgress = document.getElementById('fcOfferProgress');
  const offerMessage = document.getElementById('fcOfferMessage');
  const offerSubtext = document.getElementById('fcOfferSubtext');

  // ===== COMBINE ALL PERFUME CATALOGS =====
  let allPerfumes = [];

  function combineCatalogs() {
    allPerfumes = [];
    
    // Add from PerfumeCatalog if it exists
    if (window.PerfumeCatalog) {
      for (let brandKey in window.PerfumeCatalog) {
        if (Array.isArray(window.PerfumeCatalog[brandKey])) {
          allPerfumes.push(...window.PerfumeCatalog[brandKey]);
        }
      }
    }
    
    console.log(`✓ Combined catalog: ${allPerfumes.length} perfumes`);
  }

  // ===== FUZZY SEARCH FUNCTION (Levenshtein distance) =====
  function getLevenshteinDistance(a, b) {
    if (a.length === 0) return b.length;
    if (b.length === 0) return a.length;
    const matrix = [];
    for (let i = 0; i <= b.length; i++) matrix[i] = [i];
    for (let j = 0; j <= a.length; j++) matrix[0][j] = j;
    for (let i = 1; i <= b.length; i++) {
      for (let j = 1; j <= a.length; j++) {
        if (b.charAt(i - 1) === a.charAt(j - 1)) {
          matrix[i][j] = matrix[i - 1][j - 1];
        } else {
          matrix[i][j] = Math.min(
            matrix[i - 1][j - 1] + 1,
            matrix[i][j - 1] + 1,
            matrix[i - 1][j] + 1
          );
        }
      }
    }
    return matrix[b.length][a.length];
  }

  function getSimilarityScore(str1, str2) {
    if (!str1 || !str2) return 0;
    const s1 = String(str1).toLowerCase().trim();
    const s2 = String(str2).toLowerCase().trim();
    if (s1 === s2) return 1;
    if (s1.includes(s2) || s2.includes(s1)) return 0.9;
    const distance = getLevenshteinDistance(s1, s2);
    const maxLength = Math.max(s1.length, s2.length);
    return 1 - (distance / maxLength);
  }

  // ===== EXTRACT NUTA NAME FROM PRODUCT METAFIELDS =====
  function getNutaName(product) {
    if (product.metafields && product.metafields.custom && product.metafields.custom.nuta) {
      return product.metafields.custom.nuta.trim();
    }
    return null;
  }

  // ===== EXTRACT INSPIRED NAME FROM PRODUCT TITLE =====
  function getInspiredName(productTitle) {
    const match = productTitle.match(/Inspired by (.*)/i);
    return match ? match[1].trim() : null;
  }

  // ===== EXTRACT PRODUCT NUMBER =====
  function getProductNumber(productTitle) {
    const match = productTitle.match(/No\.?\s*(\d+)/i);
    return match ? match[1] : null;
  }

  // ===== EXTRACT NUMBER FROM CATALOG NAME =====
  function getCatalogNumber(catalogName) {
    const match = catalogName.match(/\d+/);
    return match ? match[0] : null;
  }

  // ===== FUNCTION TO GET ALL NOTES FROM CATALOG PERFUME =====
  function getCatalogNotes(catalogPerfume) {
    const notes = {
      top: (catalogPerfume.top_notes || []).map(n => n.toLowerCase().trim()),
      heart: (catalogPerfume.heart_notes || []).map(n => n.toLowerCase().trim()),
      base: (catalogPerfume.base_notes || []).map(n => n.toLowerCase().trim())
    };
    return notes;
  }

  // ===== FUNCTION TO EXTRACT NOTES FROM PRODUCT METAFIELDS =====
  function getProductNotes(product) {
    let topNotes = [];
    let heartNotes = [];
    let baseNotes = [];
    
    if (product.metafields) {
      if (product.metafields.perfume) {
        topNotes = (product.metafields.perfume.top_notes || '').split(',').map(n => n.trim().toLowerCase());
        heartNotes = (product.metafields.perfume.middle_notes || '').split(',').map(n => n.trim().toLowerCase());
        baseNotes = (product.metafields.perfume.base_notes || '').split(',').map(n => n.trim().toLowerCase());
      } else if (product.metafields.custom) {
        topNotes = (product.metafields.custom.top_notes || '').split(',').map(n => n.trim().toLowerCase());
        heartNotes = (product.metafields.custom.middle_notes || '').split(',').map(n => n.trim().toLowerCase());
        baseNotes = (product.metafields.custom.base_notes || '').split(',').map(n => n.trim().toLowerCase());
      }
    }
    
    if (topNotes.length === 0 && product.description) {
      const topMatch = product.description.match(/top notes?[:\s]+([^.!]+)/i);
      if (topMatch) {
        topNotes = topMatch[1].split(',').map(n => n.trim().toLowerCase());
      }
      
      const heartMatch = product.description.match(/(?:heart|middle) notes?[:\s]+([^.!]+)/i);
      if (heartMatch) {
        heartNotes = heartMatch[1].split(',').map(n => n.trim().toLowerCase());
      }
      
      const baseMatch = product.description.match(/base notes?[:\s]+([^.!]+)/i);
      if (baseMatch) {
        baseNotes = baseMatch[1].split(',').map(n => n.trim().toLowerCase());
      }
    }
    
    topNotes = topNotes.filter(n => n && n.length > 0);
    heartNotes = heartNotes.filter(n => n && n.length > 0);
    baseNotes = baseNotes.filter(n => n && n.length > 0);
    
    return {
      top: topNotes,
      heart: heartNotes,
      base: baseNotes,
      all: [...topNotes, ...heartNotes, ...baseNotes]
    };
  }

  // ===== GET POPULAR PRODUCTS FOR SUGGESTIONS =====
  function getPopularSuggestions() {
    if (!fcProducts || fcProducts.length === 0) return [];
    
    const suggestions = [];
    
    // Popular fragrance keywords that people often search for
    const popularKeywords = ['Sauvage', 'Chanel', 'Dior', 'No. 5', 'Bleu', 'Black Opium', 'La Vie Est Belle', 'Angel', 'J\'adore', 'Acqua'];
    
    // First, try to find products matching popular keywords
    popularKeywords.forEach(keyword => {
      const matches = fcProducts.filter(p => 
        p.title.toLowerCase().includes(keyword.toLowerCase())
      );
      suggestions.push(...matches);
    });
    
    // If we don't have enough, add some random products
    if (suggestions.length < 8) {
      const randomProducts = [...fcProducts].sort(() => 0.5 - Math.random());
      suggestions.push(...randomProducts);
    }
    
    // Remove duplicates and limit to 8
    const uniqueSuggestions = [];
    const seenIds = new Set();
    
    suggestions.forEach(product => {
      if (!seenIds.has(product.id) && uniqueSuggestions.length < 8) {
        seenIds.add(product.id);
        uniqueSuggestions.push(product);
      }
    });
    
    return uniqueSuggestions;
  }

  // ===== RENDER SUGGESTIONS =====
  function renderSuggestions() {
    const suggestions = getPopularSuggestions();
    
    if (suggestions.length === 0) return '';
    
    let html = `
      <div class="fc-suggestions-title">✨ You Might Like These</div>
    `;
    
    suggestions.forEach(product => {
      const priceFormatted = product.price ? '£' + (product.price / 100).toFixed(2) : '£9.99';
      
      let displayName = product.title;
      const inspiredMatch = product.title.match(/Inspired by (.*)/i);
      if (inspiredMatch) {
        displayName = inspiredMatch[1];
      }
      
      const tag = product.title.toLowerCase().includes('inspired by') ? '⭐ Inspired' : '🔥 Popular';
      
      html += `
        <div class="fc-suggestion-item" onclick="window.fcViewDetails('${product.url}')">
          <img class="fc-suggestion-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div class="fc-suggestion-info">
            <div class="fc-suggestion-name">${displayName}</div>
            <div class="fc-suggestion-price">${priceFormatted}</div>
            <div class="fc-suggestion-tag">${tag}</div>
          </div>
        </div>
      `;
    });
    
    return html;
  }

  // ===== COMPREHENSIVE MATCHING FOR INSPIRED PRODUCTS - FIXED =====
  function findInspiredProducts(catalogPerfume) {
    if (!fcProducts || fcProducts.length === 0 || !catalogPerfume) return [];
    
    const catalogName = catalogPerfume.name.toLowerCase();
    const catalogBrand = catalogPerfume.brand.toLowerCase();
    const catalogNumber = (catalogPerfume.name.match(/\d+/) || [])[0];
    
    // Check if this is the men's version (Code without "for women")
    const isMensVersion = catalogName === 'code' || 
                         (catalogName.includes('code') && !catalogName.includes('women') && !catalogName.includes('for'));
    
    // Check if this is the women's version
    const isWomensVersion = catalogName.includes('code for women') || 
                            catalogName.includes('code for her');
    
    console.log(`Matching for: "${catalogName}" (Men's: ${isMensVersion}, Women's: ${isWomensVersion})`);
    
    // Use a Map to store unique products with their best score
    const productMap = new Map();
    
    fcProducts.forEach(product => {
      let score = 0;
      let matchReasons = [];
      
      // Get product identifiers
      const productTitle = product.title.toLowerCase();
      const inspiredName = getInspiredName(product.title);
      const productNumber = getProductNumber(product.title);
      const nutaName = getNutaName(product);
      
      // ===== SPECIAL CASE: MEN'S VERSION OF CODE =====
      if (isMensVersion) {
        // Check if this is No. 260 - Inspired by Code (men's version)
        if (productTitle.includes('260') || productTitle.includes('no. 260')) {
          score += 2000;
          matchReasons.push('exact_product_number_260');
        }
        
        // Check if product title contains "Code" but NOT "women" or "for her"
        if (productTitle.includes('code') && 
            !productTitle.includes('women') && 
            !productTitle.includes('for women') && 
            !productTitle.includes('for her')) {
          score += 1000;
          matchReasons.push('mens_code_version');
        }
      }
      
      // ===== SPECIAL CASE: WOMEN'S VERSION OF CODE =====
      if (isWomensVersion) {
        // Check if this is No. 135 - Inspired by Code for Women
        if (productTitle.includes('135') || productTitle.includes('no. 135')) {
          score += 2000;
          matchReasons.push('exact_product_number_135');
        }
        
        // Check if product title contains "Code for Women"
        if (productTitle.includes('code for women')) {
          score += 1500;
          matchReasons.push('womens_code_version');
        }
      }
      
      // ===== METHOD 1: NUTA METAFIELD MATCHING =====
      if (nutaName) {
        const nutaLower = nutaName.toLowerCase();
        
        // Nuta exactly matches catalog name
        if (nutaLower === catalogName) {
          score += 1000;
          matchReasons.push('nuta_exact');
        }
        // Nuta contains catalog name
        else if (nutaLower.includes(catalogName)) {
          // But penalize if it's men's catalog matching women's nuta
          if (isMensVersion && nutaLower.includes('women')) {
            score += 200; // Lower score for wrong gender
            matchReasons.push('nuta_contains_wrong_gender');
          } else {
            score += 800;
            matchReasons.push('nuta_contains');
          }
        }
        // Catalog name contains nuta
        else if (catalogName.includes(nutaLower)) {
          score += 600;
          matchReasons.push('nuta_in_catalog');
        }
      }
      
      // ===== METHOD 2: INSPIRED BY TEXT MATCHING =====
      if (inspiredName) {
        const inspiredLower = inspiredName.toLowerCase();
        
        // Inspired name exactly matches catalog name
        if (inspiredLower === catalogName) {
          score += 500;
          matchReasons.push('inspired_exact');
        }
        // Inspired name contains catalog name
        else if (inspiredLower.includes(catalogName)) {
          // Penalize wrong gender matches
          if (isMensVersion && inspiredLower.includes('women')) {
            score += 150;
            matchReasons.push('inspired_contains_wrong_gender');
          } else {
            score += 400;
            matchReasons.push('inspired_contains');
          }
        }
        // Catalog name contains inspired name
        else if (catalogName.includes(inspiredLower)) {
          score += 300;
          matchReasons.push('inspired_in_catalog');
        }
      }
      
      // ===== METHOD 3: PRODUCT TITLE DIRECT MATCHING =====
      // Check if product title contains catalog name
      if (productTitle.includes(catalogName)) {
        // Penalize wrong gender matches
        if (isMensVersion && productTitle.includes('women')) {
          score += 100;
          matchReasons.push('title_contains_wrong_gender');
        } else {
          score += 300;
          matchReasons.push('title_contains');
        }
      }
      
      // Check if product title contains catalog brand
      if (catalogBrand && productTitle.includes(catalogBrand)) {
        score += 200;
        matchReasons.push('brand_in_title');
      }
      
      // Check if product title contains any catalog words
      const catalogWords = catalogName.split(/\s+/);
      catalogWords.forEach(cWord => {
        if (cWord.length > 2 && productTitle.includes(cWord)) {
          // Penalize wrong gender for "code"
          if (cWord === 'code' && isMensVersion && productTitle.includes('women')) {
            score += 25;
            matchReasons.push(`title_word_wrong_gender:${cWord}`);
          } else {
            score += 100;
            matchReasons.push(`title_word:${cWord}`);
          }
        }
      });
      
      // ===== METHOD 4: NUMBER MATCHING =====
      if (catalogNumber && productNumber && catalogNumber === productNumber) {
        score += 400;
        matchReasons.push('number_match');
      }
      
      // ===== METHOD 5: DIRECT PRODUCT NUMBER DETECTION =====
      // Check for No. 260 (men's Code)
      if (productTitle.includes('260') || productTitle.includes('no. 260')) {
        score += 300;
        matchReasons.push('product_260_detected');
      }
      
      // Check for No. 135 (women's Code)
      if (productTitle.includes('135') || productTitle.includes('no. 135')) {
        score += 300;
        matchReasons.push('product_135_detected');
      }
      
      // Only add if score is significant
      if (score > 50) {
        // If product already exists in map, keep the higher score
        if (!productMap.has(product.id) || productMap.get(product.id).score < score) {
          productMap.set(product.id, {
            product,
            score,
            matchReasons: matchReasons.join(', ')
          });
        }
      }
    });
    
    // Convert map to array and sort by score
    const matches = Array.from(productMap.values())
      .sort((a, b) => b.score - a.score);
    
    console.log(`Found ${matches.length} unique matches for "${catalogPerfume.name}"`);
    matches.forEach(m => {
      console.log(`- ${m.product.title} (score: ${m.score}, reasons: ${m.matchReasons})`);
    });
    
    return matches;
  }

  // ===== ADVANCED SEARCH FOR CATALOG =====
  function advancedCatalogSearch(query) {
    if (!query || query.length < 1) return [];
    
    const queryLower = query.toLowerCase().trim();
    const queryWords = queryLower.split(/\s+/).filter(w => w.length > 0);
    const results = [];
    
    allPerfumes.forEach(perfume => {
      let score = 0;
      
      // Searchable fields
      const searchableName = (perfume.name || '').toLowerCase();
      const searchableBrand = (perfume.brand || '').toLowerCase();
      
      // Get all notes
      const allNotes = [
        ...(perfume.top_notes || []),
        ...(perfume.heart_notes || []),
        ...(perfume.base_notes || [])
      ].map(n => n.toLowerCase()).join(' ');
      
      // ===== EXACT MATCHES =====
      if (searchableName === queryLower) score += 1000;
      if (searchableBrand === queryLower) score += 900;
      
      // ===== CONTAINS MATCHES =====
      if (searchableName.includes(queryLower)) score += 700;
      if (searchableBrand.includes(queryLower)) score += 600;
      if (allNotes.includes(queryLower)) score += 500;
      
      // ===== WORD-BY-WORD MATCHING =====
      queryWords.forEach(qWord => {
        if (qWord.length < 2) return;
        
        if (searchableName.includes(qWord)) score += 200;
        if (searchableBrand.includes(qWord)) score += 150;
        if (allNotes.includes(qWord)) score += 100;
      });
      
      // ===== SINGLE LETTER SEARCH =====
      if (query.length === 1) {
        const firstLetter = queryLower[0];
        if (searchableName[0] === firstLetter) score += 100;
        else if (searchableBrand[0] === firstLetter) score += 80;
      }
      
      if (score > 20) {
        results.push({
          ...perfume,
          matchScore: score
        });
      }
    });
    
    return results.sort((a, b) => b.matchScore - a.matchScore);
  }

  // ===== RENDER CATALOG PERFUME LIST =====
  function renderCatalogPerfumes(perfumes, query) {
    if (!perfumes || perfumes.length === 0) return '';
    
    // Sort by match score then alphabetically
    const sortedPerfumes = [...perfumes].sort((a, b) => {
      if (b.matchScore && a.matchScore && b.matchScore !== a.matchScore) {
        return b.matchScore - a.matchScore;
      }
      return a.name.localeCompare(b.name);
    });
    
    let html = `<div class="fc-section-title">Real Perfumes (${perfumes.length})</div>`;
    
    sortedPerfumes.slice(0, 8).forEach(perfume => {
      html += `
        <div class="fc-real-perfume-item" onclick="window.fcShowPerfumeDetail('${perfume.id}')">
          <img class="fc-real-perfume-image" src="${perfume.image}" 
               alt="${perfume.name}" 
               loading="lazy"
               onerror="this.src='https://via.placeholder.com/60x60?text=Perfume'">
          <div class="fc-real-perfume-info">
            <div class="fc-real-perfume-name">${perfume.name}</div>
            <div class="fc-real-perfume-brand">${perfume.brand}</div>
            ${perfume.year ? `<div class="fc-real-perfume-year">${perfume.year}</div>` : ''}
          </div>
        </div>
      `;
    });
    
    return html;
  }

  // ===== SHOW PERFUME DETAIL WITH INSPIRED PRODUCTS =====
  window.fcShowPerfumeDetail = function(perfumeId) {
    const perfume = findPerfumeById(perfumeId);
    if (!perfume) return;
    
    currentView = 'detail';
    steps.style.display = 'none';
    
    const inspiredMatches = findInspiredProducts(perfume);
    
    let html = `
      <button class="fc-back-btn" onclick="window.fcGoBack()">Back</button>
    `;
    
    if (inspiredMatches.length > 0) {
      html += `<div class="fc-subsection-title">Our Inspired Versions</div>`;
      html += '<div class="fc-grid-2col">';
      
      // First product gets "Recommended"
      if (inspiredMatches.length >= 1) {
        html += renderYourProductCard(inspiredMatches[0].product, 'Recommended', {
          score: inspiredMatches[0].score,
          matchReasons: inspiredMatches[0].matchReasons
        });
      }
      
      // Second product gets "You might like it"
      if (inspiredMatches.length >= 2) {
        html += renderYourProductCard(inspiredMatches[1].product, 'You might like it', {
          score: inspiredMatches[1].score,
          matchReasons: inspiredMatches[1].matchReasons
        });
      } else {
        // If only one match, show a random different product
        const otherProducts = fcProducts.filter(p => p.id !== inspiredMatches[0].product.id);
        if (otherProducts.length > 0) {
          const randomProduct = otherProducts[Math.floor(Math.random() * otherProducts.length)];
          html += renderYourProductCard(randomProduct, 'You might like it');
        }
      }
      
      html += '</div>';
    }
    
    // Show catalog perfume details
    html += `
      <div class="fc-detailed-view">
        <div class="fc-detailed-header">
          <img class="fc-detailed-image" src="${perfume.image}" 
               alt="${perfume.name}"
               loading="lazy"
               onerror="this.src='https://via.placeholder.com/110x110?text=Perfume'">
          <div>
            <div class="fc-detailed-name">${perfume.name}</div>
            <div class="fc-detailed-brand">${perfume.brand}</div>
            ${perfume.year ? `<div class="fc-detailed-meta">${perfume.year}</div>` : ''}
            ${perfume.gender ? `<div class="fc-detailed-meta">${perfume.gender}</div>` : ''}
          </div>
        </div>

        <div class="fc-notes-section">
          ${perfume.top_notes ? `
            <div class="fc-note-category">
              <h4>TOP NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.top_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${perfume.heart_notes ? `
            <div class="fc-note-category">
              <h4>HEART NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.heart_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${perfume.base_notes ? `
            <div class="fc-note-category">
              <h4>BASE NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.base_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
        </div>
        
        <div class="fc-description">
          ${perfume.description}
        </div>
      </div>
    `;
    
    content.innerHTML = html;
  };

  // ===== FIND PERFUME BY ID =====
