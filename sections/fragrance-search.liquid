  padding: 14px 28px;
  cursor: pointer;
  box-shadow: 0 8px 20px rgba(196, 30, 58, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: all 0.3s ease;
  border: none;
  min-width: 130px;
}

.fc-search-toggle:hover {
  background: #A51D36;
  transform: translateY(-3px);
  box-shadow: 0 12px 25px rgba(165, 29, 54, 0.4);
}

.fc-search-toggle svg {
