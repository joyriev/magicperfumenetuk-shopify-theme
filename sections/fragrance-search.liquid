  // ===== FUZZY CATALOG SEARCH (OPTIMIZED) =====
  function fuzzyCatalogSearch(query) {
    if (!query || query.length < 1) return [];
    
    const searchVariants = createSearchVariants(query);
    const results = [];
    const addedIds = new Set();
    
    allPerfumes.forEach(perfume => {
      let bestScore = 0;
      
      // Quick checks on brand and name first
      if (perfume.brand) {
        const brandLower = perfume.brand.toLowerCase();
        const queryLower = query.toLowerCase();
        
        // Exact brand match
        if (brandLower === queryLower || brandLower.includes(queryLower)) {
          bestScore = 95;
        }
      }
      
      if (perfume.name && bestScore < 90) {
        const nameLower = perfume.name.toLowerCase();
        const queryLower = query.toLowerCase();
        
        // Exact name match
        if (nameLower === queryLower || nameLower.includes(queryLower)) {
          bestScore = 100;
        }
      }
      
      // Check variants (only if not already matched)
      if (bestScore < 85) {
        for (const variant of searchVariants) {
          if (bestScore >= 90) break;
          if (variant.length < 2) continue;
          
          const searchableText = [
            perfume.name,
            perfume.brand
          ].join(' ').toLowerCase();
          
          if (searchableText.includes(variant)) {
            bestScore = Math.max(bestScore, 85);
            break;
          }
        }
      }
      
      // Minimal fuzzy matching (only on brand/name, not full text)
      if (bestScore < 70 && searchVariants[0]) {
        if (perfume.brand) {
          const brandScore = getAdvancedFuzzySimilarity(searchVariants[0], perfume.brand.toLowerCase());
          if (brandScore > 65) {
            bestScore = brandScore;
          }
        }
        
        if (bestScore < 70 && perfume.name) {
          const nameScore = getAdvancedFuzzySimilarity(searchVariants[0], perfume.name.toLowerCase());
          if (nameScore > 65) {
            bestScore = nameScore;
          }
        }
      }
      
      if (bestScore > 40 && !addedIds.has(perfume.id)) {
        results.push({ perfume, score: bestScore });
        addedIds.add(perfume.id);
      }
    });
    
    return results.sort((a, b) => b.score - a.score).map(r => r.perfume);
  }

