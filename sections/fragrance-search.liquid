<script>
(function() {
  let fcProducts = [];
  let allPerfumes = [];
  let currentView = 'search';
  let currentSearchQuery = '';
  let searchTimer = null;

  const stickyButton  = document.getElementById('fcStickyButton');
  const searchPopup   = document.getElementById('fcSearchPopup');
  const searchInput   = document.getElementById('fcSearchInput');
  const clearSearch   = document.getElementById('fcClearSearch');
  const steps         = document.getElementById('fcSteps');
  const content       = document.getElementById('fcContent');
  const offerBanner   = document.getElementById('fcOfferBanner');
  const offerStatus   = document.getElementById('fcOfferStatus');
  const offerProgress = document.getElementById('fcOfferProgress');
  const offerMessage  = document.getElementById('fcOfferMessage');
  const offerSubtext  = document.getElementById('fcOfferSubtext');

  // ============================================================
  // LEVENSHTEIN — catches typos & spelling mistakes
  // e.g. "sauvge" → matches "Sauvage", "chanl" → "Chanel"
  // ============================================================
  function levenshtein(a, b) {
    a = a.toLowerCase(); b = b.toLowerCase();
    const m = a.length, n = b.length;
    const dp = Array.from({length: m + 1}, (_, i) => [i]);
    for (let j = 0; j <= n; j++) dp[0][j] = j;
    for (let i = 1; i <= m; i++) {
      for (let j = 1; j <= n; j++) {
        dp[i][j] = a[i-1] === b[j-1]
          ? dp[i-1][j-1]
          : 1 + Math.min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1]);
      }
    }
    return dp[m][n];
  }

  // Every word in query must fuzzily match at least one word in target
  function fuzzyContains(target, query) {
    if (!target || !query) return false;
    target = target.toLowerCase().trim();
    query  = query.toLowerCase().trim();
    if (target.includes(query)) return true;

    const qWords = query.split(/\s+/);
    const tWords = target.split(/\s+/);

    return qWords.every(qw => {
      if (qw.length <= 2) return target.includes(qw);
      return tWords.some(tw => {
        const dist = levenshtein(qw, tw);
        // Allow 1 typo for words ≤5 chars, 2 typos for longer words
        const threshold = qw.length <= 5 ? 1 : 2;
        return dist <= threshold;
      });
    });
  }

  // ============================================================
  // EXTRACT "INSPIRED BY ..." NAME FROM PRODUCT TITLE
  // "No. 260 - Inspired by Code" → "code"
  // "No. 135 - Inspired by Code for Women" → "code for women"
  // ============================================================
  function getInspiredName(title) {
    const m = title.match(/inspired\s+by\s+(.+)/i);
    return m ? m[1].trim().toLowerCase() : null;
  }

  // ============================================================
  // SCORE: how well does ONE product match a catalog perfume?
  //
  // THE KEY FIX:
  //   Catalog: "Armani Code"  → catalogNameNoBrand = "code"
  //   Product: "Inspired by Code"          → inspiredName = "code"       → EXACT → 1000 ✅
  //   Product: "Inspired by Code for Women"→ inspiredName = "code for women"
  //            extra words ["for","women"] → score = 60 (penalised) ✅
  // ============================================================
  function scoreProduct(product, catalogPerfume) {
    const catalogName  = (catalogPerfume.name  || '').toLowerCase().trim();
    const catalogBrand = (catalogPerfume.brand || '').toLowerCase().trim();
    const inspiredName = getInspiredName(product.title);

    let score = 0;

    if (inspiredName) {
      // Strip brand from catalog name: "armani code" → "code"
      const catalogNoBrand = catalogName.replace(catalogBrand, '').trim();

      if (inspiredName === catalogName || inspiredName === catalogNoBrand) {
        // Perfect match: "code" === "code"
        score = 1000;

      } else {
        const inspiredWords  = inspiredName.split(/\s+/);
        const catalogWords   = catalogNoBrand.split(/\s+/).filter(w => w.length > 1);

        // How many catalog-name words appear in the inspired name
        const matchedWords = catalogWords.filter(cw => inspiredWords.includes(cw)).length;
        // How many EXTRA words does inspired name have beyond the catalog name
        const extraWords   = inspiredWords.filter(w => w.length > 1 && !catalogWords.includes(w)).length;

        if (matchedWords === catalogWords.length && extraWords === 0) {
          score = 900; // all catalog words match, zero extras

        } else if (matchedWords === catalogWords.length && extraWords > 0) {
          // "code for women" when catalog is "code" — penalise heavily per extra word
          score = Math.max(0, 200 - (extraWords * 80));
          // score = 120 for 1 extra, 40 for 2 extras — below our 200 threshold → ignored

        } else if (matchedWords > 0) {
          score = matchedWords * 60; // partial word overlap
        }
      }
    }

    // Small brand bonus
    if (catalogBrand && product.title.toLowerCase().includes(catalogBrand)) score += 10;

    return Math.max(score, 0);
  }

  // ============================================================
  // FIND INSPIRED PRODUCTS for detail page
  // Only returns products with score ≥ 200 (genuine matches)
  // ============================================================
  function findInspiredProducts(catalogPerfume) {
    if (!fcProducts.length || !catalogPerfume) return [];

    const seen = new Set();
    return fcProducts
      .map(p => ({ product: p, score: scoreProduct(p, catalogPerfume) }))
      .filter(x => x.score >= 200)
      .sort((a, b) => b.score - a.score)
      .filter(x => {
        if (seen.has(x.product.id)) return false;
        seen.add(x.product.id);
        return true;
      });
  }

  // ============================================================
  // CATALOG SEARCH — fuzzy, returns sorted catalog perfumes
  // ============================================================
  function combineCatalogs() {
    allPerfumes = [];
    if (window.PerfumeCatalog) {
      Object.values(window.PerfumeCatalog).forEach(arr => {
        if (Array.isArray(arr)) allPerfumes.push(...arr);
      });
    }
    console.log('✓ Catalog:', allPerfumes.length, 'perfumes');
  }

  function catalogSearch(query) {
    if (!query || query.length < 1) return [];
    const q = query.toLowerCase().trim();

    return allPerfumes
      .map(p => {
        const name  = (p.name  || '').toLowerCase();
        const brand = (p.brand || '').toLowerCase();
        const notes = [
          ...(p.top_notes   || []),
          ...(p.heart_notes || []),
          ...(p.base_notes  || [])
        ].join(' ').toLowerCase();

        let score = 0;
        if (name === q)               score = 1000;
        else if (name.startsWith(q))  score = 900;
        else if (name.includes(q))    score = 800;
        else if (fuzzyContains(name, q)) score = 600;

        if (brand === q)              score += 300;
        else if (brand.includes(q))   score += 200;
        else if (fuzzyContains(brand, q)) score += 100;

        if (notes.includes(q))        score += 50;

        return { ...p, _score: score };
      })
      .filter(p => p._score > 0)
      .sort((a, b) => b._score - a._score);
  }

  // ============================================================
  // "OUR VERSIONS" SEARCH — strict scoring, no false positives
  //
  // Searching "code":
  //   "Inspired by Code"          → inspiredName="code"           → score 1000 ✅ shown
  //   "Inspired by Code for Women"→ inspiredName="code for women" → extra words → score 120 → filtered out ✅
  //   "Inspired by Le Male"       → no match                      → score 0    → filtered out ✅
  // ============================================================
  function searchOurProducts(query) {
    if (!query || query.length < 1) return [];
    const q = query.toLowerCase().trim();

    const seen = new Set();
    return fcProducts
      .map(product => {
        const inspiredName = getInspiredName(product.title);
        const titleLower   = product.title.toLowerCase();
        let score = 0;

        if (inspiredName) {
          if (inspiredName === q) {
            score = 1000; // "code" === "code"

          } else if (fuzzyContains(inspiredName, q)) {
            const inspiredWords = inspiredName.split(/\s+/);
            const queryWords    = q.split(/\s+/);
            // Words in inspired name that are NOT in the query
            const extraWords = inspiredWords.filter(w =>
              w.length > 2 && !queryWords.some(qw => levenshtein(qw, w) <= 1)
            ).length;

            if (extraWords === 0) {
              score = 800; // all query words found, nothing extra
            } else {
              // Penalise: 1 extra word → 300, 2 → 100, 3+ → 0
              score = Math.max(0, 400 - (extraWords * 150));
            }
          }
        }

        // Fallback: fuzzy match on full title (for brand searches etc.)
        if (score === 0 && fuzzyContains(titleLower, q)) score = 150;

        return { product, score };
      })
      .filter(x => x.score >= 500) // HIGH threshold — only show exact/near-exact matches
      .sort((a, b) => b.score - a.score)
      .filter(x => {
        if (seen.has(x.product.id)) return false;
        seen.add(x.product.id);
        return true;
      })
      .map(x => x.product);
  }

  // ============================================================
  // RENDER HELPERS
  // ============================================================
  function renderCatalogPerfumes(perfumes) {
    if (!perfumes.length) return '';
    let html = `<div class="fc-section-title">Real Perfumes (${perfumes.length})</div>`;
    perfumes.slice(0, 8).forEach(p => {
      html += `
        <div class="fc-real-perfume-item" onclick="window.fcShowPerfumeDetail('${p.id}')">
          <img class="fc-real-perfume-image" src="${p.image}" alt="${p.name}" loading="lazy"
               onerror="this.src='https://via.placeholder.com/60x60?text=Perfume'">
          <div class="fc-real-perfume-info">
            <div class="fc-real-perfume-name">${p.name}</div>
            <div class="fc-real-perfume-brand">${p.brand}</div>
            ${p.year ? `<div class="fc-real-perfume-year">${p.year}</div>` : ''}
          </div>
        </div>`;
    });
    return html;
  }

  function renderYourProductCard(product, badge) {
    const price = product.price ? '£' + (product.price / 100).toFixed(2) : '£9.99';
    const numMatch = product.title.match(/No\.?\s*(\d+)/i);
    const displayNum = numMatch ? numMatch[0] : '';
    const inspiredMatch = product.title.match(/inspired\s+by\s+(.*)/i);
    const displayName = inspiredMatch ? inspiredMatch[1] : product.title;

    return `
      <div class="fc-product-card">
        <div class="fc-badge">${badge}</div>
        <div class="fc-product-inner">
          <img class="fc-product-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div class="fc-product-title">${displayNum ? displayNum + ' - ' : ''}${displayName}</div>
          <div class="fc-product-price">${price}</div>
          <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart(${product.variant})">Add to Cart</button>
          <div><span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${product.url}')">View Details</span></div>
        </div>
      </div>`;
  }

  function renderSuggestions() {
    const keywords = ['Sauvage', 'Chanel', 'Bleu', 'Black Opium', 'Angel', 'Acqua'];
    const seen = new Set();
    const suggestions = [];
    keywords.forEach(kw => {
      fcProducts.filter(p => p.title.toLowerCase().includes(kw.toLowerCase())).forEach(p => {
        if (!seen.has(p.id) && suggestions.length < 8) { seen.add(p.id); suggestions.push(p); }
      });
    });
    if (suggestions.length < 8) {
      [...fcProducts].sort(() => 0.5 - Math.random()).forEach(p => {
        if (!seen.has(p.id) && suggestions.length < 8) { seen.add(p.id); suggestions.push(p); }
      });
    }
    if (!suggestions.length) return '';
    let html = '<div class="fc-suggestions-title">✨ You Might Like These</div>';
    suggestions.forEach(p => {
      const price = p.price ? '£' + (p.price / 100).toFixed(2) : '£9.99';
      const m = p.title.match(/inspired\s+by\s+(.*)/i);
      const name = m ? m[1] : p.title;
      html += `
        <div class="fc-suggestion-item" onclick="window.fcViewDetails('${p.url}')">
          <img class="fc-suggestion-image" src="${p.image}" alt="${p.title}" loading="lazy">
          <div class="fc-suggestion-info">
            <div class="fc-suggestion-name">${name}</div>
            <div class="fc-suggestion-price">${price}</div>
            <div class="fc-suggestion-tag">⭐ Inspired</div>
          </div>
        </div>`;
    });
    return html;
  }

  // ============================================================
  // DETAIL PAGE
  // ============================================================
  window.fcShowPerfumeDetail = function(perfumeId) {
    const perfume = allPerfumes.find(p => p.id === perfumeId);
    if (!perfume) return;

    currentView = 'detail';
    steps.style.display = 'none';

    const matches = findInspiredProducts(perfume);

    let html = `<button class="fc-back-btn" onclick="window.fcGoBack()">Back</button>`;

    if (matches.length > 0) {
      html += `<div class="fc-subsection-title">Our Inspired Versions</div><div class="fc-grid-2col">`;
      html += renderYourProductCard(matches[0].product, 'Recommended');
      if (matches.length >= 2) {
        html += renderYourProductCard(matches[1].product, 'You might like it');
      } else {
        const other = fcProducts.find(p => p.id !== matches[0].product.id);
        if (other) html += renderYourProductCard(other, 'You might like it');
      }
      html += '</div>';
    } else {
      html += `<div class="fc-no-results">No inspired versions found for "${perfume.name}"</div>`;
    }

    const notesBlock = (label, notes) => notes && notes.length ? `
      <div class="fc-note-category">
        <h4>${label}</h4>
        <div class="fc-note-tags">${notes.map(n => `<span class="fc-note-tag">${n}</span>`).join('')}</div>
      </div>` : '';

    html += `
      <div class="fc-detailed-view">
        <div class="fc-detailed-header">
          <img class="fc-detailed-image" src="${perfume.image}" alt="${perfume.name}" loading="lazy"
               onerror="this.src='https://via.placeholder.com/110x110?text=Perfume'">
          <div>
            <div class="fc-detailed-name">${perfume.name}</div>
            <div class="fc-detailed-brand">${perfume.brand}</div>
            ${perfume.year   ? `<div class="fc-detailed-meta">${perfume.year}</div>`   : ''}
            ${perfume.gender ? `<div class="fc-detailed-meta">${perfume.gender}</div>` : ''}
          </div>
        </div>
        <div class="fc-notes-section">
          ${notesBlock('TOP NOTES',   perfume.top_notes)}
          ${notesBlock('HEART NOTES', perfume.heart_notes)}
          ${notesBlock('BASE NOTES',  perfume.base_notes)}
        </div>
        ${perfume.description ? `<div class="fc-description">${perfume.description}</div>` : ''}
      </div>`;

    content.innerHTML = html;
  };

  // ============================================================
  // PERFORM SEARCH
  // ============================================================
  function performSearch(query) {
    currentSearchQuery = query;
    content.innerHTML = '<div class="fc-loading">Searching...</div>';

    setTimeout(() => {
      const catalogResults = catalogSearch(query);
      const ourVersions    = searchOurProducts(query);

      let html = '';

      if (catalogResults.length > 0) {
        html += renderCatalogPerfumes(catalogResults);
      }

      if (ourVersions.length > 0) {
        html += `<div class="fc-section-title">Our Versions (${ourVersions.length})</div>`;
        ourVersions.slice(0, 6).forEach(p => {
          const price = p.price ? '£' + (p.price / 100).toFixed(2) : '£9.99';
          html += `
            <div class="fc-real-perfume-item" onclick="window.fcViewDetails('${p.url}')">
              <img class="fc-real-perfume-image" src="${p.image}" alt="${p.title}" loading="lazy">
              <div class="fc-real-perfume-info">
                <div class="fc-real-perfume-name">${p.title}</div>
                <div class="fc-real-perfume-year">${price}</div>
              </div>
            </div>`;
        });
      }

      if (!catalogResults.length && !ourVersions.length) {
        html = `<div class="fc-no-results">No results for "${query}"</div>`;
        html += renderSuggestions();
      }

      content.innerHTML = html;
    }, 250);
  }

  // ============================================================
  // CART & OFFER BANNER
  // ============================================================
  function updateOfferDisplay(count) {
    const pct = Math.min((count / 3) * 100, 100);
    offerProgress.style.width = pct + '%';
    if (count >= 3) {
      offerStatus.textContent  = '🎉 FREE!';
      offerSubtext.textContent = 'You qualify for a free gift!';
      offerMessage.textContent = '🎉 You qualify for a FREE gift!';
      offerBanner.classList.add('qualified');
    } else {
      const needed = 3 - count;
      offerStatus.textContent  = `${count}/3`;
      offerSubtext.textContent = `Add ${needed} more for a free gift`;
      offerMessage.textContent = `Add ${needed} more item${needed > 1 ? 's' : ''} to get a free gift`;
      offerBanner.classList.remove('qualified');
    }
  }

  function fetchCartAndUpdate() {
    return fetch('/cart.js')
      .then(r => r.json())
      .then(cart => { updateOfferDisplay(cart.item_count); return cart; })
      .catch(() => ({ item_count: 0 }));
  }

  window.fcAddToCart = function(variantId) {
    const btn  = event.target;
    const orig = btn.innerText;
    btn.innerText = 'Adding...'; btn.disabled = true;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(r => r.json())
    .then(() => {
      btn.innerText = '✓ Added!'; btn.style.background = '#2E7D32';
      fetchCartAndUpdate().then(cart => showNotification(`✓ Added! ${cart.item_count}/3 items for free gift`));
      setTimeout(() => { btn.innerText = orig; btn.style.background = ''; btn.disabled = false; }, 2000);
    })
    .catch(() => {
      btn.innerText = 'Error'; btn.style.background = '#c62828';
      setTimeout(() => { btn.innerText = orig; btn.style.background = ''; btn.disabled = false; }, 1500);
    });
  };

  function showNotification(msg) {
    let n = document.querySelector('.fc-notification');
    if (!n) { n = document.createElement('div'); n.className = 'fc-notification'; document.body.appendChild(n); }
    n.textContent = msg; n.classList.add('show');
    setTimeout(() => n.classList.remove('show'), 2500);
  }

  // ============================================================
  // TOGGLE & EVENTS
  // ============================================================
  window.fcToggleSearch = function() {
    const isOpen = searchPopup.classList.contains('active');
    searchPopup.classList.toggle('active');
    if (!isOpen) { searchInput.focus(); fetchCartAndUpdate(); }
  };

  window.fcViewDetails = function(url) { window.location.href = url; };

  window.fcGoBack = function() {
    currentView = 'search';
    if (currentSearchQuery.length >= 1) performSearch(currentSearchQuery);
    else { steps.style.display = 'block'; content.innerHTML = ''; }
  };

  // ============================================================
  // INIT SHOPIFY PRODUCTS
  // ============================================================
  function fcInitProducts() {
    fcProducts = [
      {% for product in collections.all.products %}
        {
          id: {{ product.id | json }},
          title: {{ product.title | json }},
          image: {{ product.featured_image | img_url: '400x' | json }},
          url: {{ product.url | json }},
          variant: {{ product.variants.first.id | json }},
          price: {{ product.price | json }},
          comparePrice: {{ product.compare_at_price | json }},
          description: {{ product.description | strip_html | json }},
          metafields: {
            custom: {
              nuta: {{ product.metafields.custom.nuta | default: '' | json }}
            }
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
    console.log('✓ Loaded', fcProducts.length, 'products');
  }

  // ============================================================
  // BOOT
  // ============================================================
  document.addEventListener('DOMContentLoaded', function() {
    fcInitProducts();
    combineCatalogs();

    searchInput.addEventListener('keyup', function() {
      const q = searchInput.value.trim();
      if (q.length < 1) {
        if (currentView !== 'detail') { steps.style.display = 'block'; content.innerHTML = ''; }
        return;
      }
      steps.style.display = 'none';
      currentView = 'search';
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => performSearch(q), 300);
    });

    clearSearch.addEventListener('click', function() {
      searchInput.value = '';
      searchInput.focus();
      steps.style.display = 'block';
      content.innerHTML = '';
      currentView = 'search';
    });

    setTimeout(fetchCartAndUpdate, 500);

    document.addEventListener('click', function(e) {
      if (!searchPopup.contains(e.target) && !stickyButton.contains(e.target) && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') searchPopup.classList.remove('active');
    });

    searchPopup.addEventListener('click', e => e.stopPropagation());
  });

})();
</script>
