  // ===== PERFORM SEARCH WITH ENHANCED FUZZY MATCHING =====
  function performSearch(query) {
    currentSearchQuery = query;
    content.innerHTML = '<div class="fc-loading">Searching...</div>';
    
    setTimeout(() => {
      // Use enhanced search for our products
      const results = enhancedFuzzySearch(query);
      
      // Use FUZZY catalog search for real perfumes (now works with typos!)
      const catalogResults = fuzzyCatalogSearch(query);
      
      let html = '';
      
      // Show Real Perfumes catalog FIRST (NOW with fuzzy matching!)
      if (catalogResults.length > 0) {
        html += renderCatalogPerfumes(catalogResults, query);
      }
      
      // Show Our Products AFTER catalog
      if (results.length > 0) {
        html += `<div class="fc-section-title">Our Products (${results.length})</div>`;
        
        results.slice(0, 8).forEach(match => {
          const p = match.product;
          const priceFormatted = '£' + (p.price / 100).toFixed(2);
          
          html += `
            <div class="fc-real-perfume-item" onclick="window.fcViewDetails('${p.url}')">
              <img class="fc-real-perfume-image" src="${p.image}" alt="${p.title}" loading="lazy" onerror="this.src='https://via.placeholder.com/60x60?text=Perfume'">
              <div class="fc-real-perfume-info">
                <div class="fc-real-perfume-name">${p.title}</div>
                <div class="fc-real-perfume-year">${priceFormatted}</div>
              </div>
            </div>
          `;
        });
      }
      
      // If NO RESULTS AT ALL, show suggestions
      if (catalogResults.length === 0 && results.length === 0) {
        html = '<div class="fc-no-results">No products found for "' + query + '"</div>';
        html += renderSuggestions();
      }
      
      content.innerHTML = html;
    }, 300);
  }

  // ===== SEARCH HANDLER =====
  function fcHandleSearch() {
    const query = searchInput.value.trim();
    
    if (query.length < 1) {
      if (currentView !== 'detail') {
        steps.style.display = 'block';
        content.innerHTML = '';
      }
      return;
    }
    
    steps.style.display = 'none';
    currentView = 'search';
    
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => performSearch(query), 300);
  }

  // ===== INITIALIZE =====
  document.addEventListener('DOMContentLoaded', function() {
    fcInitProducts();
    combineCatalogs();
    searchInput.addEventListener('keyup', fcHandleSearch);
    
    clearSearch.addEventListener('click', function() {
      searchInput.value = '';
      searchInput.focus();
      steps.style.display = 'block';
      content.innerHTML = '';
      currentView = 'search';
    });
    
    setTimeout(fetchCartAndUpdate, 500);
    
    document.addEventListener('click', function(event) {
      if (!searchPopup.contains(event.target) && !stickyButton.contains(event.target) && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    searchPopup.addEventListener('click', function(e) {
      e.stopPropagation();
    });
  });

})();

// ===== ENSURE ALL GLOBAL FUNCTIONS ARE AVAILABLE =====
// These are already defined inside the IIFE but need to be explicitly attached to window

// Make sure fcToggleSearch is available globally
if (typeof window.fcToggleSearch !== 'function') {
  console.warn('fcToggleSearch not found, reattaching...');
  window.fcToggleSearch = function() {
    const searchPopup = document.getElementById('fcSearchPopup');
    const searchInput = document.getElementById('fcSearchInput');
    if (searchPopup.classList.contains('active')) {
      searchPopup.classList.remove('active');
    } else {
      searchPopup.classList.add('active');
      if (searchInput) searchInput.focus();
      // Try to fetch cart update if function exists
      if (typeof fetchCartAndUpdate === 'function') {
        fetchCartAndUpdate();
      }
    }
  };
}

// Make sure fcAddToCart is available globally
if (typeof window.fcAddToCart !== 'function') {
  console.warn('fcAddToCart not found, providing fallback...');
  window.fcAddToCart = function(productUrl, event) {
    if (event) event.stopPropagation();
    alert('Add to cart function loading. Please try again in a moment.');
  };
}

// Make sure fcViewDetails is available globally
if (typeof window.fcViewDetails !== 'function') {
  window.fcViewDetails = function(url) {
    window.location.href = url;
  };
}

// Make sure fcShowPerfumeDetail is available globally
if (typeof window.fcShowPerfumeDetail !== 'function') {
  window.fcShowPerfumeDetail = function(perfumeId) {
    console.log('Detail view for:', perfumeId);
  };
}

// Make sure fcGoBack is available globally
if (typeof window.fcGoBack !== 'function') {
  window.fcGoBack = function() {
    const steps = document.getElementById('fcSteps');
    const content = document.getElementById('fcContent');
    if (steps) steps.style.display = 'block';
    if (content) content.innerHTML = '';
  };
}

console.log('✅ All global functions attached to window');
</script>