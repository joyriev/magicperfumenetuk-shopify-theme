<script>
(function() {
  // ===== YOUR SHOPIFY PRODUCTS =====
  let fcProducts = [];
  let currentView = 'search';
  let currentSearchQuery = '';
  
  // Debounce timer
  let searchTimer = null;

  // Get elements
  const stickyButton = document.getElementById('fcStickyButton');
  const searchPopup = document.getElementById('fcSearchPopup');
  const searchInput = document.getElementById('fcSearchInput');
  const clearSearch = document.getElementById('fcClearSearch');
  const steps = document.getElementById('fcSteps');
  const content = document.getElementById('fcContent');
  
  // Offer elements
  const offerBanner = document.getElementById('fcOfferBanner');
  const offerStatus = document.getElementById('fcOfferStatus');
  const offerProgress = document.getElementById('fcOfferProgress');
  const offerMessage = document.getElementById('fcOfferMessage');
  const offerSubtext = document.getElementById('fcOfferSubtext');

  // ===== COMBINE ALL PERFUME CATALOGS =====
  let allPerfumes = [];

  function combineCatalogs() {
    allPerfumes = [];
    
    // Add from PerfumeCatalog if it exists
    if (window.PerfumeCatalog) {
      for (let brandKey in window.PerfumeCatalog) {
        if (Array.isArray(window.PerfumeCatalog[brandKey])) {
          allPerfumes.push(...window.PerfumeCatalog[brandKey]);
        }
      }
    }
    
    console.log(`✓ Combined catalog: ${allPerfumes.length} perfumes`);
  }

  // ===== FUZZY SEARCH FUNCTION (Levenshtein distance) =====
  function getLevenshteinDistance(a, b) {
    if (a.length === 0) return b.length;
    if (b.length === 0) return a.length;
    const matrix = [];
    for (let i = 0; i <= b.length; i++) matrix[i] = [i];
    for (let j = 0; j <= a.length; j++) matrix[0][j] = j;
    for (let i = 1; i <= b.length; i++) {
      for (let j = 1; j <= a.length; j++) {
        if (b.charAt(i - 1) === a.charAt(j - 1)) {
          matrix[i][j] = matrix[i - 1][j - 1];
        } else {
          matrix[i][j] = Math.min(
            matrix[i - 1][j - 1] + 1,
            matrix[i][j - 1] + 1,
            matrix[i - 1][j] + 1
          );
        }
      }
    }
    return matrix[b.length][a.length];
  }

  function getSimilarityScore(str1, str2) {
    if (!str1 || !str2) return 0;
    const s1 = String(str1).toLowerCase().trim();
    const s2 = String(str2).toLowerCase().trim();
    if (s1 === s2) return 1;
    if (s1.includes(s2) || s2.includes(s1)) return 0.9;
    const distance = getLevenshteinDistance(s1, s2);
    const maxLength = Math.max(s1.length, s2.length);
    return 1 - (distance / maxLength);
  }

  // ===== HELPER FUNCTION TO SAFELY GET STRING FROM NOTES =====
  function getNotesString(notes) {
    if (!notes) return '';
    if (typeof notes === 'string') return notes.toLowerCase();
    if (Array.isArray(notes)) return notes.join(' ').toLowerCase();
    return String(notes).toLowerCase();
  }

  // ===== ENHANCED SEARCH WITH FUZZY MATCHING =====
  function searchCatalog(query) {
    if (allPerfumes.length === 0 || query.length < 1) return [];
    
    const results = [];
    const queryLower = query.toLowerCase().trim();
    const firstLetter = queryLower[0];
    
    // Common misspellings mapping for better fuzzy matching
    const commonMisspellings = {
      'savauge': 'sauvage',
      'savge': 'sauvage',
      'savag': 'sauvage',
      'chanle': 'chanel',
      'channel': 'chanel',
      'avanus': 'aventus',
      'adventus': 'aventus',
      'cread': 'creed',
      'tom four': 'tom ford',
      'dior home': 'dior homme',
      'jadore': "j'adore",
      'j ador': "j'adore",
      'baccarat': 'baccarat rouge',
      'rouge': 'baccarat rouge',
      'ysl': 'yves saint laurent',
      'yves saint laurence': 'yves saint laurent'
    };
    
    // Check if query matches a common misspelling
    let correctedQuery = queryLower;
    for (let [misspelling, correct] of Object.entries(commonMisspellings)) {
      if (queryLower.includes(misspelling)) {
        correctedQuery = queryLower.replace(misspelling, correct);
        break;
      }
    }
    
    allPerfumes.forEach(perfume => {
      const perfumeNameLower = perfume.name.toLowerCase();
      const perfumeBrandLower = perfume.brand.toLowerCase();
      
      // Get all notes for searching
      const allNotes = [
        ...(perfume.top_notes || []),
        ...(perfume.heart_notes || []),
        ...(perfume.base_notes || [])
      ].map(n => n.toLowerCase());
      
      const allNotesStr = allNotes.join(' ');
      const searchableText = `${perfumeNameLower} ${perfumeBrandLower} ${perfume.year} ${allNotesStr}`.toLowerCase();
      
      let score = 0;
      
      // EXACT NAME MATCH (highest priority)
      if (perfumeNameLower === queryLower) {
        score += 1000;
      }
      // NAME STARTS WITH QUERY
      else if (perfumeNameLower.startsWith(queryLower)) {
        score += 500;
      }
      // NAME CONTAINS QUERY
      else if (perfumeNameLower.includes(queryLower)) {
        score += 300;
      }
      // BRAND MATCH
      else if (perfumeBrandLower.includes(queryLower)) {
        score += 200;
      }
      // NOTE MATCH (any note contains the query)
      else if (allNotes.some(note => note.includes(queryLower))) {
        score += 150;
      }
      // FUZZY NAME MATCH (for typos)
      else {
        const nameSimilarity = getSimilarityScore(perfumeNameLower, queryLower);
        if (nameSimilarity > 0.7) {
          score += nameSimilarity * 100;
        }
      }
      
      if (score > 0) {
        results.push({ ...perfume, matchScore: score });
      }
    });
    
    // Sort by relevance score (higher first) - NO LIMIT, return ALL matches
    return results.sort((a, b) => b.matchScore - a.matchScore);
  }

  // ===== FIND PERFUME BY ID =====
  function findPerfumeById(id) {
    return allPerfumes.find(p => p.id === id);
  }

  // ===== FIND MATCHING PRODUCTS BY FRAGRANCE COMPOSITION =====
  function findMatchingProductsByComposition(catalogPerfume) {
    if (!fcProducts || fcProducts.length === 0 || !catalogPerfume) return [];
    
    // Get all notes from catalog perfume
    const catalogNotes = [
      ...(catalogPerfume.top_notes || []),
      ...(catalogPerfume.heart_notes || []),
      ...(catalogPerfume.base_notes || [])
    ].map(n => n.toLowerCase().trim());
    
    // Get fragrance family from description
    const catalogDesc = (catalogPerfume.description || '').toLowerCase();
    
    // Score each product based on note similarity
    const scoredProducts = fcProducts.map(product => {
      // Get product notes from metafields
      const productTopNotes = (product.topNotes || '').toLowerCase().split(',').map(n => n.trim()).filter(n => n);
      const productMiddleNotes = (product.middleNotes || '').toLowerCase().split(',').map(n => n.trim()).filter(n => n);
      const productBaseNotes = (product.baseNotes || '').toLowerCase().split(',').map(n => n.trim()).filter(n => n);
      const productAllNotes = [...productTopNotes, ...productMiddleNotes, ...productBaseNotes];
      
      let matchScore = 0;
      let matchedNotes = [];
      
      // Check each catalog note against product notes
      catalogNotes.forEach(catalogNote => {
        productAllNotes.forEach(productNote => {
          // Exact note match
          if (productNote === catalogNote) {
            matchScore += 50;
            matchedNotes.push(catalogNote);
          }
          // Partial match (e.g., "vanilla" matches "madagascar vanilla")
          else if (productNote.includes(catalogNote) || catalogNote.includes(productNote)) {
            if (productNote.length > 3 && catalogNote.length > 3) {
              matchScore += 25;
              matchedNotes.push(catalogNote);
            }
          }
          // Fuzzy match for similar notes
          else {
            const similarity = getSimilarityScore(productNote, catalogNote);
            if (similarity > 0.8) {
              matchScore += similarity * 20;
              matchedNotes.push(catalogNote);
            }
          }
        });
      });
      
      // Bonus for matching fragrance families
      const productDesc = (product.description || '').toLowerCase();
      const productTitle = (product.title || '').toLowerCase();
      
      // Define fragrance families with keywords
      const families = [
        { name: 'floral', keywords: ['floral', 'flower', 'rose', 'jasmine', 'lavender', 'iris'] },
        { name: 'citrus', keywords: ['citrus', 'orange', 'lemon', 'bergamot', 'grapefruit', 'mandarin'] },
        { name: 'woody', keywords: ['woody', 'wood', 'cedar', 'sandalwood', 'vetiver', 'oakmoss'] },
        { name: 'oriental', keywords: ['oriental', 'amber', 'vanilla', 'tonka', 'spice', 'incense'] },
        { name: 'fresh', keywords: ['fresh', 'aquatic', 'ocean', 'sea', 'water', 'green'] },
        { name: 'sweet', keywords: ['sweet', 'gourmand', 'vanilla', 'caramel', 'honey', 'praline'] },
        { name: 'spicy', keywords: ['spicy', 'pepper', 'cinnamon', 'clove', 'cardamom', 'saffron'] }
      ];
      
      families.forEach(family => {
        // Check if catalog perfume belongs to this family
        const catalogInFamily = family.keywords.some(keyword => 
          catalogDesc.includes(keyword) || catalogNotes.some(note => note.includes(keyword))
        );
        
        // Check if product belongs to this family
        const productInFamily = family.keywords.some(keyword => 
          productDesc.includes(keyword) || productTitle.includes(keyword) || 
          productAllNotes.some(note => note.includes(keyword))
        );
        
        if (catalogInFamily && productInFamily) {
          matchScore += 30;
        }
      });
      
      // Bonus for gender match
      if (catalogPerfume.gender && product.gender) {
        const catalogGender = catalogPerfume.gender.toLowerCase();
        const productGender = product.gender.toLowerCase();
        if (catalogGender === productGender) {
          matchScore += 20;
        } else if (catalogGender === 'unisex' || productGender === 'unisex') {
          matchScore += 10;
        }
      }
      
      return {
        product,
        matchScore,
        matchedNotes: [...new Set(matchedNotes)] // Unique matched notes
      };
    });
    
    // Filter products with at least some match and sort by score
    return scoredProducts
      .filter(item => item.matchScore > 20)
      .sort((a, b) => b.matchScore - a.matchScore)
      .slice(0, 4) // Get top 4 matches
      .map(item => ({
        ...item.product,
        matchScore: item.matchScore,
        matchedNotes: item.matchedNotes
      }));
  }

  // ===== RENDER CATALOG PERFUME LIST - SHOW ALL RESULTS =====
  function renderCatalogPerfumes(perfumes, query) {
    if (!perfumes || perfumes.length === 0) return '';
    
    let html = `<div class="fc-section-title">Real ${query} Perfumes (${perfumes.length})</div>`;
    
    perfumes.forEach(perfume => {
      html += `
        <div class="fc-real-perfume-item" onclick="window.fcShowPerfumeDetail('${perfume.id}')">
          <img class="fc-real-perfume-image" src="${perfume.image}" 
               alt="${perfume.name}" 
               loading="lazy"
               onerror="this.src='https://via.placeholder.com/60x60?text=Perfume'">
          <div class="fc-real-perfume-info">
            <div class="fc-real-perfume-name">${perfume.name}</div>
            <div class="fc-real-perfume-brand">${perfume.brand}</div>
            ${perfume.year ? `<div class="fc-real-perfume-year">${perfume.year}</div>` : ''}
          </div>
        </div>
      `;
    });
    
    return html;
  }

  // ===== SHOW PERFUME DETAIL FROM CATALOG WITH MATCHING PRODUCTS =====
  window.fcShowPerfumeDetail = function(perfumeId) {
    const perfume = findPerfumeById(perfumeId);
    if (!perfume) return;
    
    currentView = 'detail';
    steps.style.display = 'none';
    
    // Find matching products based on fragrance composition
    const matchingProducts = findMatchingProductsByComposition(perfume);
    
    let html = `
      <button class="fc-back-btn" onclick="window.fcGoBack()">Back</button>
    `;
    
    // Show matching products based on composition
    if (matchingProducts.length > 0) {
      html += `<div class="fc-subsection-title">Perfect Match by Scent Profile (${matchingProducts.length})</div>`;
      html += '<div class="fc-grid-2col">';
      
      // First product gets "Recommended" badge
      if (matchingProducts.length >= 1) {
        html += renderYourProductCard(matchingProducts[0], 'Recommended', matchingProducts[0].matchedNotes);
      }
      
      // Second product gets "You might like it" badge
      if (matchingProducts.length >= 2) {
        html += renderYourProductCard(matchingProducts[1], 'You might like it', matchingProducts[1].matchedNotes);
      } else if (matchingProducts.length === 1) {
        // If only one product, duplicate with different badge
        html += renderYourProductCard(matchingProducts[0], 'You might like it', matchingProducts[0].matchedNotes);
      }
      
      html += '</div>';
    }
    
    // Show catalog perfume details
    html += `
      <div class="fc-detailed-view">
        <div class="fc-detailed-header">
          <img class="fc-detailed-image" src="${perfume.image}" 
               alt="${perfume.name}"
               loading="lazy"
               onerror="this.src='https://via.placeholder.com/110x110?text=Perfume'">
          <div>
            <div class="fc-detailed-name">${perfume.name}</div>
            <div class="fc-detailed-brand">${perfume.brand}</div>
            ${perfume.year ? `<div class="fc-detailed-meta">${perfume.year}</div>` : ''}
            ${perfume.gender ? `<div class="fc-detailed-meta">${perfume.gender}</div>` : ''}
          </div>
        </div>

        <div class="fc-notes-section">
          ${perfume.top_notes ? `
            <div class="fc-note-category">
              <h4>TOP NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.top_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${perfume.heart_notes ? `
            <div class="fc-note-category">
              <h4>HEART NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.heart_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${perfume.base_notes ? `
            <div class="fc-note-category">
              <h4>BASE NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.base_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
        </div>
        
        <div class="fc-description">
          ${perfume.description}
        </div>
      </div>
    `;
    
    content.innerHTML = html;
  };

  // ===== INITIALIZE YOUR SHOPIFY PRODUCTS =====
  function fcInitProducts() {
    fcProducts = [
      {% for product in collections.all.products %}
        {
          id: {{ product.id | json }},
          title: {{ product.title | json }},
          image: {{ product.featured_image | img_url: '400x' | json }},
          url: {{ product.url | json }},
          variant: {{ product.variants.first.id | json }},
          price: {{ product.price | json }},
          comparePrice: {{ product.compare_at_price | json }},
          description: {{ product.description | strip_html | json }},
          fragranceComposition: {{ product.metafields.perfume.composition | default: '' | json }},
          topNotes: {{ product.metafields.perfume.top_notes | default: '' | json }},
          middleNotes: {{ product.metafields.perfume.middle_notes | default: '' | json }},
          baseNotes: {{ product.metafields.perfume.base_notes | default: '' | json }},
          gender: {{ product.metafields.perfume.gender | default: 'Unisex' | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
    console.log('✓ Loaded', fcProducts.length, 'products');
  }

  // ===== SHOW NOTIFICATION =====
  function showNotification(message) {
    let notification = document.querySelector('.fc-notification');
    if (!notification) {
      notification = document.createElement('div');
      notification.className = 'fc-notification';
      document.body.appendChild(notification);
    }
    
    notification.textContent = message;
    notification.classList.add('show');
    
    setTimeout(() => {
      notification.classList.remove('show');
    }, 2000);
  }

  // ===== UPDATE OFFER DISPLAY =====
  function updateOfferDisplay(itemCount) {
    if (!offerStatus || !offerProgress || !offerMessage || !offerSubtext) return;
    
    const percentage = Math.min((itemCount / 3) * 100, 100);
    offerProgress.style.width = percentage + '%';
    
    if (itemCount >= 3) {
      offerStatus.textContent = '🎉 FREE!';
      offerSubtext.textContent = 'You qualify for a free gift!';
      offerMessage.textContent = '🎉 You qualify for a FREE gift!';
      offerBanner.classList.add('qualified');
    } else {
      const needed = 3 - itemCount;
      offerStatus.textContent = `${itemCount}/3`;
      offerSubtext.textContent = `Add ${needed} more for a free gift`;
      offerMessage.textContent = `Add ${needed} more item${needed > 1 ? 's' : ''} to get a free gift`;
      offerBanner.classList.remove('qualified');
    }
  }

  // ===== TOGGLE POPUP =====
  window.fcToggleSearch = function() {
    if (searchPopup.classList.contains('active')) {
      searchPopup.classList.remove('active');
    } else {
      searchPopup.classList.add('active');
      searchInput.focus();
      // Update cart count when popup opens
      fetchCartAndUpdate();
    }
  };

  // ===== FETCH CART AND UPDATE COUNT =====
  function fetchCartAndUpdate() {
    return fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        // Update all cart count elements
        document.querySelectorAll('.cart-count, [data-cart-count]').forEach(el => {
          if (el) el.textContent = cart.item_count;
        });
        
        // Update offer display
        updateOfferDisplay(cart.item_count);
        
        return cart;
      })
      .catch(error => {
        console.error('Error fetching cart:', error);
        return { item_count: 0 };
      });
  }

  // ===== UPDATE CART COUNT AND OFFER =====
  function updateCartCount() {
    return fetchCartAndUpdate();
  }

  // ===== ADD TO CART - FIXED TO UPDATE IMMEDIATELY WITHOUT REFRESH =====
  window.fcAddToCart = function(variantId) {
    const btn = event.target;
    const originalText = btn.innerText;
    const originalBackground = btn.style.background;
    
    btn.innerText = 'Adding...';
    btn.disabled = true;
    
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ 
        id: variantId, 
        quantity: 1 
      })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error('Network response was not ok');
      }
      return response.json();
    })
    .then(data => {
      btn.innerText = '✓ Added!';
      btn.style.background = '#2E7D32';
      
      // Immediately fetch updated cart to get the new count
      fetchCartAndUpdate().then(cart => {
        console.log('Cart updated immediately:', cart.item_count);
        
        // Show success notification with current count
        showNotification(`✓ Added! ${cart.item_count}/3 items for free gift`);
      });
      
      // Reset button after 2 seconds
      setTimeout(() => {
        btn.innerText = originalText;
        btn.style.background = originalBackground || '#C41E3A';
        btn.disabled = false;
      }, 2000);
    })
    .catch(error => {
      console.error('Error adding to cart:', error);
      btn.innerText = 'Error';
      btn.style.background = '#c62828';
      
      setTimeout(() => {
        btn.innerText = originalText;
        btn.style.background = originalBackground || '#C41E3A';
        btn.disabled = false;
      }, 1500);
    });
  };

  // ===== RENDER YOUR PRODUCT CARD WITH MATCHED NOTES =====
  function renderYourProductCard(product, badge, matchedNotes = []) {
    const priceFormatted = product.price ? '£' + (product.price / 100).toFixed(2) : '';
    
    let displayName = product.title;
    const inspiredMatch = product.title.match(/Inspired by (.*)/i);
    if (inspiredMatch) {
      displayName = inspiredMatch[1];
    }
    
    // Show matched notes as a tooltip/hint
    const matchedNotesHint = matchedNotes.length > 0 
      ? `<div style="font-size: 10px; color: #C41E3A; margin-top: 5px;">Matches: ${matchedNotes.slice(0, 3).join(', ')}</div>` 
      : '';
    
    return `
      <div class="fc-product-card">
        <div class="fc-badge">${badge}</div>
        <div class="fc-product-inner" onclick="window.fcShowYourProductDetail(${product.id})">
          <img class="fc-product-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 5px;">${displayName}</div>
          <div style="font-size: 14px; font-weight: 800; color: #C41E3A; margin-bottom: 10px;">${priceFormatted}</div>
          ${matchedNotesHint}
          <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart(${product.variant})">Add to Cart</button>
          <div>
            <span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${product.url}')">View Details</span>
          </div>
        </div>
      </div>
    `;
  }

  // ===== SHOW YOUR PRODUCT DETAIL =====
  window.fcShowYourProductDetail = function(productId) {
    const product = fcProducts.find(p => p.id === productId);
    if (!product) return;
    
    currentView = 'detail';
    steps.style.display = 'none';
    
    const priceFormatted = product.price ? '£' + (product.price / 100).toFixed(2) : '';
    const topNotes = typeof product.topNotes === 'string' ? product.topNotes.split(',').map(n => n.trim()) : [];
    const middleNotes = typeof product.middleNotes === 'string' ? product.middleNotes.split(',').map(n => n.trim()) : [];
    const baseNotes = typeof product.baseNotes === 'string' ? product.baseNotes.split(',').map(n => n.trim()) : [];
    
    let displayName = product.title;
    const inspiredMatch = product.title.match(/Inspired by (.*)/i);
    if (inspiredMatch) {
      displayName = inspiredMatch[1];
    }
    
    let html = `
      <button class="fc-back-btn" onclick="window.fcGoBack()">Back</button>
      
      <div class="fc-detailed-view">
        <div class="fc-detailed-header">
          <img class="fc-detailed-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div>
            <div class="fc-detailed-name">${displayName}</div>
            <div class="fc-detailed-brand">${product.title.split('-')[0].trim()}</div>
            <div style="font-size: 18px; font-weight: 800; color: #C41E3A; margin-top: 10px;">${priceFormatted}</div>
          </div>
        </div>

        <div class="fc-notes-section">
          ${topNotes.length > 0 ? `
            <div class="fc-note-category">
              <h4>TOP NOTES</h4>
              <div class="fc-note-tags">
                ${topNotes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${middleNotes.length > 0 ? `
            <div class="fc-note-category">
              <h4>HEART NOTES</h4>
              <div class="fc-note-tags">
                ${middleNotes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${baseNotes.length > 0 ? `
            <div class="fc-note-category">
              <h4>BASE NOTES</h4>
              <div class="fc-note-tags">
                ${baseNotes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${product.fragranceComposition ? `
            <div class="fc-note-category">
              <h4>COMPOSITION</h4>
              <div class="fc-note-tags">
                <span class="fc-note-tag">${product.fragranceComposition}</span>
              </div>
            </div>
          ` : ''}
        </div>
      </div>
    `;
    
    content.innerHTML = html;
  };

  // ===== VIEW DETAILS =====
  window.fcViewDetails = function(url) {
    window.location.href = url;
  };

  // ===== GO BACK =====
  window.fcGoBack = function() {
    currentView = 'search';
    if (currentSearchQuery.length >= 1) {
      performSearch(currentSearchQuery);
    } else {
      steps.style.display = 'block';
      content.innerHTML = '';
    }
  };

  // ===== PERFORM SEARCH =====
  function performSearch(query) {
    currentSearchQuery = query;
    content.innerHTML = '<div class="fc-loading">Searching...</div>';
    
    setTimeout(() => {
      // Search in our combined catalog - returns ALL matches, no limit
      const catalogResults = searchCatalog(query);
      
      let html = '';
      
      // Show catalog perfumes first (ALL of them)
      if (catalogResults.length > 0) {
        html += renderCatalogPerfumes(catalogResults, query);
      }
      
      // If no results from catalog
      if (catalogResults.length === 0) {
        html = '<div class="fc-no-results">No products found</div>';
      }
      
      content.innerHTML = html;
    }, 300);
  }

  // ===== SEARCH HANDLER WITH DEBOUNCE =====
  function fcHandleSearch() {
    const query = searchInput.value.trim();
    
    if (query.length < 1) {
      if (currentView !== 'detail') {
        steps.style.display = 'block';
        content.innerHTML = '';
      }
      return;
    }
    
    steps.style.display = 'none';
    currentView = 'search';
    
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => performSearch(query), 300);
  }

  // ===== INITIALIZE =====
  document.addEventListener('DOMContentLoaded', function() {
    fcInitProducts();
    combineCatalogs();
    searchInput.addEventListener('keyup', fcHandleSearch);
    
    // Clear search button
    clearSearch.addEventListener('click', function() {
      searchInput.value = '';
      searchInput.focus();
      steps.style.display = 'block';
      content.innerHTML = '';
      currentView = 'search';
    });
    
    // Initial cart count
    setTimeout(updateCartCount, 500);
    
    document.addEventListener('click', function(event) {
      if (!searchPopup.contains(event.target) && !stickyButton.contains(event.target) && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    searchPopup.addEventListener('click', function(e) {
      e.stopPropagation();
    });
  });

})();
</script>