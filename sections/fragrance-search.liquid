  // ===== ADVANCED SEARCH WITH FUZZY MATCHING =====
  function advancedFuzzySearch(query) {
    if (allPerfumes.length === 0 || query.length < 1) return [];
    
    const results = [];
    const queryLower = query.toLowerCase().trim();
    const queryWords = queryLower.split(/\s+/).filter(w => w.length > 0);
    
    allPerfumes.forEach(perfume => {
      const searchableText = getCatalogSearchableText(perfume);
      const searchableWords = searchableText.split(/\s+/).filter(w => w.length > 1);
      
      let totalScore = 0;
      let matchedWords = [];
      
      // Check each query word
      queryWords.forEach(queryWord => {
        if (queryWord.length < 1) return;
        
        // Exact match
        if (searchableText.includes(queryWord)) {
          totalScore += 100;
          matchedWords.push(queryWord);
          return;
        }
        
        // Word starts with query
        searchableWords.forEach(word => {
          if (word.startsWith(queryWord)) {
            totalScore += 50;
            matchedWords.push(word);
          }
        });
        
        // Fuzzy match
        const bestMatch = getBestFuzzyMatch(queryWord, searchableWords);
        if (bestMatch.match) {
          totalScore += bestMatch.score * 70;
          matchedWords.push(bestMatch.match);
        }
      });
      
      // Bonus for brand match
      if (perfume.brand.toLowerCase().includes(queryLower)) {
        totalScore += 150;
      }
      
      // Bonus for multiple matches
      const uniqueMatched = [...new Set(matchedWords)];
      totalScore += uniqueMatched.length * 20;
      
      if (totalScore > 20) {
        results.push({ ...perfume, matchScore: totalScore });
      }
    });
    
    return results.sort((a, b) => b.matchScore - a.matchScore);
  }

  // ===== GET BEST FUZZY MATCH =====
  function getBestFuzzyMatch(word, wordList) {
    let bestMatch = null;
    let bestScore = 0;
    
    wordList.forEach(targetWord => {
      const score = getSimilarityScore(word, targetWord);
      if (score > bestScore && score > 0.5) {
        bestScore = score;
        bestMatch = targetWord;
      }
    });
    
    return { match: bestMatch, score: bestScore };
  }

  // ===== FIND PERFUME BY ID =====
  function findPerfumeById(id) {
    return allPerfumes.find(p => p.id === id);
  }

  // ===== FIND INSPIRED PRODUCTS =====
  function findInspiredProducts(catalogPerfume) {
    if (!fcProducts || fcProducts.length === 0 || !catalogPerfume) return [];
    
    const catalogName = catalogPerfume.name.toLowerCase();
    const catalogBrand = catalogPerfume.brand.toLowerCase();
    
    const scoredProducts = fcProducts.map(product => {
      const productTitle = product.title.toLowerCase();
      let matchScore = 0;
      let matchType = '';
      
      // Check for "Inspired by" match
      if (productTitle.includes('inspired by')) {
        const inspiredMatch = product.title.match(/Inspired by (.*)/i);
        if (inspiredMatch) {
          const inspiredName = inspiredMatch[1].toLowerCase().trim();
          
          // Exact match
          if (inspiredName === catalogName) {
            matchScore += 1000;
            matchType = 'exact';
          }
          // Partial match
          else if (inspiredName.includes(catalogName) || catalogName.includes(inspiredName)) {
            matchScore += 500;
            matchType = 'partial';
          }
          // Fuzzy match
          else {
            const similarity = getSimilarityScore(inspiredName, catalogName);
            if (similarity > 0.6) {
              matchScore += similarity * 300;
              matchType = 'fuzzy';
            }
          }
        }
      }
      
      // Note matching (always do this)
      const noteMatch = matchProductNotes(catalogPerfume, product);
      matchScore += noteMatch.score;
      
      return {
        product,
        matchScore,
        matchType,
        matchedNotes: noteMatch.matchedNotes
      };
    });
    
    return scoredProducts
      .filter(item => item.matchScore > 30)
      .sort((a, b) => b.matchScore - a.matchScore);
  }

  // ===== RENDER CATALOG PERFUME LIST =====
  function renderCatalogPerfumes(perfumes, query) {
    if (!perfumes || perfumes.length === 0) return '';
    
    let html = `<div class="fc-section-title">Real Perfumes (${perfumes.length})</div>`;
    
    perfumes.slice(0, 8).forEach(perfume => {
