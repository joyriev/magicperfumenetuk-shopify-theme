<script>
(function() {
  // ===== YOUR SHOPIFY PRODUCTS =====
  let fcProducts = [];
  let currentView = 'search';
  let currentSearchQuery = '';
  
  // Debounce timer
  let searchTimer = null;

  // Get elements
  const stickyButton = document.getElementById('fcStickyButton');
  const searchPopup = document.getElementById('fcSearchPopup');
  const searchInput = document.getElementById('fcSearchInput');
  const clearSearch = document.getElementById('fcClearSearch');
  const steps = document.getElementById('fcSteps');
  const content = document.getElementById('fcContent');
  
  // Offer elements
  const offerBanner = document.getElementById('fcOfferBanner');
  const offerStatus = document.getElementById('fcOfferStatus');
  const offerProgress = document.getElementById('fcOfferProgress');
  const offerMessage = document.getElementById('fcOfferMessage');
  const offerSubtext = document.getElementById('fcOfferSubtext');

  // ===== COMBINE ALL PERFUME CATALOGS =====
  let allPerfumes = [];

  function combineCatalogs() {
    allPerfumes = [];
    
    // Add from PerfumeCatalog if it exists
    if (window.PerfumeCatalog) {
      // Get all array properties (brands)
      for (let brandKey in window.PerfumeCatalog) {
        if (Array.isArray(window.PerfumeCatalog[brandKey])) {
          allPerfumes.push(...window.PerfumeCatalog[brandKey]);
        }
      }
    }
    
    console.log(`✓ Combined catalog: ${allPerfumes.length} perfumes`);
  }

  // ===== EXTRACT PRODUCT NUMBER FROM TITLE =====
  function extractProductNumber(title) {
    if (!title) return null;
    const match = title.match(/No\.?\s*(\d+)/i);
    return match ? match[1] : null;
  }

  // ===== FIND PERFUME BY ID =====
  function findPerfumeById(id) {
    return allPerfumes.find(p => p.id === id);
  }

  // ===== LEVENSHTEIN DISTANCE ALGORITHM FOR FUZZY MATCHING =====
  function levenshteinDistance(a, b) {
    if (a.length === 0) return b.length;
    if (b.length === 0) return a.length;
    
    const matrix = [];
    
    // Initialize matrix
    for (let i = 0; i <= b.length; i++) {
      matrix[i] = [i];
    }
    
    for (let j = 0; j <= a.length; j++) {
      matrix[0][j] = j;
    }
    
    // Fill matrix
    for (let i = 1; i <= b.length; i++) {
      for (let j = 1; j <= a.length; j++) {
        if (b.charAt(i - 1) === a.charAt(j - 1)) {
          matrix[i][j] = matrix[i - 1][j - 1];
        } else {
          matrix[i][j] = Math.min(
            matrix[i - 1][j - 1] + 1, // substitution
            matrix[i][j - 1] + 1,     // insertion
            matrix[i - 1][j] + 1      // deletion
          );
        }
      }
    }
    
    return matrix[b.length][a.length];
  }

  // ===== CALCULATE SIMILARITY BETWEEN TWO STRINGS (FUZZY MATCH) =====
  function calculateSimilarity(str1, str2) {
    if (!str1 || !str2) return 0;
    
    const s1 = str1.toLowerCase();
    const s2 = str2.toLowerCase();
    
    // Exact match
    if (s1 === s2) return 1;
    
    // One contains the other
    if (s1.includes(s2) || s2.includes(s1)) {
      return 0.9;
    }
    
    // Calculate Levenshtein distance for fuzzy matching
    const distance = levenshteinDistance(s1, s2);
    const maxLength = Math.max(s1.length, s2.length);
    
    if (maxLength === 0) return 1;
    
    // Convert distance to similarity score (0-1)
    const similarity = 1 - (distance / maxLength);
    
    return similarity;
  }

  // ===== GENERATE QUERY VARIATIONS FOR BETTER MATCHING =====
  function generateQueryVariations(query) {
    const variations = [query];
    
    // Add common variations
    if (query.includes('chanel blue')) {
      variations.push('bleu de chanel');
      variations.push('bleu chanel');
      variations.push('chanel bleu');
    }
    
    if (query.includes('bleu de chanel')) {
      variations.push('chanel blue');
      variations.push('blue chanel');
    }
    
    // Handle common misspellings
    if (query.includes('channel')) {
      variations.push(query.replace('channel', 'chanel'));
    }
    
    if (query.includes('noir')) {
      variations.push('noir');
    }
    
    if (query.includes('no 5') || query.includes('number 5')) {
      variations.push('no. 5');
      variations.push('chanel no 5');
    }
    
    // Remove numbers from query for broader matching
    const withoutNumbers = query.replace(/\d+/g, '').trim();
    if (withoutNumbers && withoutNumbers !== query) {
      variations.push(withoutNumbers);
    }
    
    // Remove spaces for matching concatenated words
    const withoutSpaces = query.replace(/\s+/g, '');
    if (withoutSpaces !== query) {
      variations.push(withoutSpaces);
    }
    
    return [...new Set(variations)]; // Remove duplicates
  }

  // ===== SIMPLE SEARCH FUNCTION WITH FUZZY MATCHING =====
  function searchProducts(query) {
    if (!query || query.length < 1 || !fcProducts || fcProducts.length === 0) {
      return [];
    }
    
    const queryLower = query.toLowerCase().trim();
    const results = [];
    const addedIds = new Set();
    
    console.log('🔍 Searching for:', queryLower);
    
    // FIRST: Special handling for "code"
    if (queryLower.includes('code')) {
      // Find No. 260 (men's)
      const no260 = fcProducts.find(p => 
        p.title.toLowerCase().includes('no. 260') || 
        p.title.toLowerCase().includes('no 260')
      );
      
      if (no260) {
        results.push({ product: no260, score: 1000 });
        addedIds.add(no260.id);
        console.log('✅ Found No. 260 for "code"');
      }
      
      // Find No. 135 (women's)
      const no135 = fcProducts.find(p => 
        p.title.toLowerCase().includes('no. 135') || 
        p.title.toLowerCase().includes('no 135')
      );
      
      if (no135 && !addedIds.has(no135.id)) {
        results.push({ product: no135, score: 900 });
        addedIds.add(no135.id);
        console.log('✅ Found No. 135 for "code"');
      }
    }
    
    // Create variations of the search query for better matching
    const queryVariations = generateQueryVariations(queryLower);
    console.log('Query variations:', queryVariations);
    
    // SECOND: Check ALL products with fuzzy matching
    fcProducts.forEach(product => {
      if (addedIds.has(product.id)) return;
      
      const title = product.title.toLowerCase();
      let score = 0;
      let matched = false;
      let matchReasons = [];
      
      // Check each variation against the title
      for (const variation of queryVariations) {
        // Direct contains match (highest score)
        if (title.includes(variation)) {
          score += 100;
          matched = true;
          matchReasons.push(`direct:${variation}`);
          break; // Found a match, no need to check other variations
        }
      }
      
      // If no direct match, try fuzzy matching
      if (!matched) {
        // Split query into words
        const queryWords = queryLower.split(/\s+/).filter(w => w.length > 2);
        
        // Split title into words
        const titleWords = title.split(/\s+/);
        
        for (const qWord of queryWords) {
          for (const tWord of titleWords) {
            // Check if word contains the query word (partial match)
            if (tWord.includes(qWord)) {
              score += 30;
              matched = true;
              matchReasons.push(`partial:${qWord} in ${tWord}`);
              break;
            }
            
            // Check if query word contains the title word
            if (qWord.includes(tWord) && tWord.length > 2) {
              score += 25;
              matched = true;
              matchReasons.push(`reverse:${tWord} in ${qWord}`);
              break;
            }
            
            // FUZZY MATCH: Check if words are similar (typo tolerance)
            const similarity = calculateSimilarity(qWord, tWord);
            if (similarity > 0.7) { // 70% similarity threshold
              score += 20 * similarity;
              matched = true;
              matchReasons.push(`fuzzy:${qWord}~${tWord} (${Math.round(similarity*100)}%)`);
              break;
            }
          }
        }
      }
      
      // Check for number matches (always exact)
      const numberMatch = product.title.match(/No\.?\s*(\d+)/i);
      if (numberMatch && queryLower.includes(numberMatch[1])) {
        score += 150;
        matched = true;
        matchReasons.push(`number:${numberMatch[1]}`);
      }
      
      // Special handling for common misspellings
      if (!matched) {
        // Handle "chanel blue" vs "bleu de chanel"
        if ((queryLower.includes('chanel') || queryLower.includes('channel')) && 
            (queryLower.includes('blue') || queryLower.includes('bleu'))) {
          if (title.includes('bleu') && title.includes('chanel')) {
            score += 80;
            matched = true;
            matchReasons.push('special:chanel blue');
          }
        }
        
        // Handle "noir" vs "noir"
        if (queryLower.includes('noir') || queryLower.includes('noire')) {
          if (title.includes('noir')) {
            score += 80;
            matched = true;
            matchReasons.push('special:noir');
          }
        }
        
        // Handle "no. 5" vs "number 5" etc.
        if (queryLower.includes('5') || queryLower.includes('five')) {
          if (title.includes('no. 5') || title.includes('no 5')) {
            score += 80;
            matched = true;
            matchReasons.push('special:no5');
          }
        }
      }
      
      if (matched) {
        results.push({ product, score, matchReasons });
        addedIds.add(product.id);
        console.log(`✅ Match: ${product.title} (Score: ${score})`, matchReasons);
      }
    });
    
    // If no matches at all, show some products as fallback
    if (results.length === 0) {
      console.log('⚠️ No matches found, showing random products');
      fcProducts.slice(0, 10).forEach(product => {
        if (!addedIds.has(product.id)) {
          results.push({ product, score: 1, matchReasons: ['fallback'] });
          addedIds.add(product.id);
        }
      });
    }
    
    // Sort by score (highest first)
    results.sort((a, b) => b.score - a.score);
    
    console.log(`📊 Found ${results.length} results for "${query}"`);
    if (results.length > 0) {
      console.log('🏆 Top result:', results[0].product.title, 'Score:', results[0].score);
    }
    
    return results;
  }

  // ===== GET POPULAR PRODUCTS FOR SUGGESTIONS =====
  function getPopularSuggestions() {
    if (!fcProducts || fcProducts.length === 0) return [];
    
    // Return top products as suggestions
    return fcProducts.slice(0, 8);
  }

  // ===== RENDER SUGGESTIONS =====
  function renderSuggestions() {
    const suggestions = getPopularSuggestions();
    
    if (suggestions.length === 0) return '';
    
    let html = `<div class="fc-suggestions-title">✨ Popular Fragrances</div>`;
    
    suggestions.forEach(product => {
      const priceFormatted = product.price ? '£' + (product.price / 100).toFixed(2) : '£9.99';
      
      html += `
        <div class="fc-suggestion-item" onclick="window.fcViewDetails('${product.url}')">
          <img class="fc-suggestion-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div class="fc-suggestion-info">
            <div class="fc-suggestion-name">${product.title}</div>
            <div class="fc-suggestion-price">${priceFormatted}</div>
          </div>
        </div>
      `;
    });
    
    return html;
  }

  // ===== SIMPLE SEARCH FOR CATALOG =====
  function simpleCatalogSearch(query) {
    if (!query || query.length < 1) return [];
    
    const queryLower = query.toLowerCase().trim();
    const results = [];
    
    allPerfumes.forEach(perfume => {
      const searchableName = (perfume.name || '').toLowerCase();
      const searchableBrand = (perfume.brand || '').toLowerCase();
      
      if (searchableName.includes(queryLower) || searchableBrand.includes(queryLower)) {
        results.push(perfume);
      }
    });
    
    return results.sort((a, b) => a.name.localeCompare(b.name));
  }

  // ===== RENDER CATALOG PERFUME LIST =====
  function renderCatalogPerfumes(perfumes, query) {
    if (!perfumes || perfumes.length === 0) return '';
    
    const sortedPerfumes = [...perfumes].sort((a, b) => a.name.localeCompare(b.name));
    
    let html = `<div class="fc-section-title">Real Perfumes (${perfumes.length})</div>`;
    
    sortedPerfumes.slice(0, 8).forEach(perfume => {
      html += `
        <div class="fc-real-perfume-item" onclick="window.fcShowPerfumeDetail('${perfume.id}')">
          <img class="fc-real-perfume-image" src="${perfume.image}" 
               alt="${perfume.name}" 
               loading="lazy"
               onerror="this.src='https://via.placeholder.com/60x60?text=Perfume'">
          <div class="fc-real-perfume-info">
            <div class="fc-real-perfume-name">${perfume.name}</div>
            <div class="fc-real-perfume-brand">${perfume.brand}</div>
            ${perfume.year ? `<div class="fc-real-perfume-year">${perfume.year}</div>` : ''}
          </div>
        </div>
      `;
    });
    
    return html;
  }

  // ===== SHOW PERFUME DETAIL WITH HARDCODED MAPPINGS =====
  window.fcShowPerfumeDetail = function(perfumeId) {
    const perfume = findPerfumeById(perfumeId);
    if (!perfume) return;
    
    currentView = 'detail';
    steps.style.display = 'none';
    
    // Find matching Shopify product using hardcoded mappings
    const shopifyProduct = findShopifyProductByCatalogPerfume(perfume);
    
    let html = `
      <button class="fc-back-btn" onclick="window.fcGoBack()">Back</button>
    `;
    
    if (shopifyProduct) {
      html += `<div class="fc-subsection-title">Our Inspired Version</div>`;
      html += '<div class="fc-grid-2col">';
      
      // RECOMMENDED: The found Shopify product
      html += renderProductCard(shopifyProduct, 'Recommended');
      
      // YOU MIGHT LIKE IT: Random product from your collection
      const otherProducts = fcProducts.filter(p => p.id !== shopifyProduct.id);
      if (otherProducts.length > 0) {
        const randomProduct = otherProducts[Math.floor(Math.random() * otherProducts.length)];
        html += renderProductCard(randomProduct, 'You might like it');
      }
      
      html += '</div>';
    } else {
      // Fallback - show random products
      html += `<div class="fc-subsection-title">You Might Like</div>`;
      html += '<div class="fc-grid-2col">';
      
      const randomProducts = [...fcProducts].sort(() => 0.5 - Math.random()).slice(0, 2);
      if (randomProducts.length >= 1) {
        html += renderProductCard(randomProducts[0], 'Recommended');
      }
      if (randomProducts.length >= 2) {
        html += renderProductCard(randomProducts[1], 'You might like it');
      }
      
      html += '</div>';
    }
    
    // Show catalog perfume details
    html += `
      <div class="fc-detailed-view">
        <div class="fc-detailed-header">
          <img class="fc-detailed-image" src="${perfume.image}" 
               alt="${perfume.name}"
               loading="lazy"
               onerror="this.src='https://via.placeholder.com/110x110?text=Perfume'">
          <div>
            <div class="fc-detailed-name">${perfume.name}</div>
            <div class="fc-detailed-brand">${perfume.brand}</div>
            ${perfume.year ? `<div class="fc-detailed-meta">${perfume.year}</div>` : ''}
            ${perfume.gender ? `<div class="fc-detailed-meta">${perfume.gender}</div>` : ''}
          </div>
        </div>

        <div class="fc-notes-section">
          ${perfume.top_notes ? `
            <div class="fc-note-category">
              <h4>TOP NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.top_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${perfume.heart_notes ? `
            <div class="fc-note-category">
              <h4>HEART NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.heart_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${perfume.base_notes ? `
            <div class="fc-note-category">
              <h4>BASE NOTES</h4>
              <div class="fc-note-tags">
                ${perfume.base_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
              </div>
            </div>
          ` : ''}
        </div>
        
        <div class="fc-description">
          ${perfume.description}
        </div>
      </div>
    `;
    
    content.innerHTML = html;
  };

  // ===== FIND SHOPIFY PRODUCT BY CATALOG PERFUME - WITH HARDCODED MAPPINGS =====
  function findShopifyProductByCatalogPerfume(perfume) {
    if (!perfume || !fcProducts.length) return null;
    
    console.log('🔍 Finding Shopify product for catalog perfume:', perfume.name);
    
    // ===== HARDCODED DIRECT MAPPINGS FOR KNOWN PRODUCTS =====
    const hardcodedMappings = [
      {
        catalogNames: ['musc noir', 'narciso rodriguez musc noir', 'musc noir narciso rodriguez'],
        productNumber: '457',
        variantId: 52698256146799, // 30ml variant
        expectedTitle: 'No. 457 - Inspired by Musc Noir For Her',
        imageUrl: 'https://magicperfume.co.uk/cdn/shop/files/457W_c.webp?v=1771765712&width=1200',
        url: 'https://magicperfume.co.uk/products/magic-perfume-no-457w',
        price: 999
      },
      {
        catalogNames: ['no. 5', 'chanel no. 5', 'no 5 chanel'],
        productNumber: '077',
        variantId: 52698252493167, // 30ml variant
        expectedTitle: 'No. 077 - Inspired by No. 5',
        imageUrl: 'https://magicperfume.co.uk/cdn/shop/files/077W_c.webp?v=1771765712&width=1200',
        url: 'https://magicperfume.co.uk/products/magic-perfume-no-077w',
        price: 999
      },
      {
        catalogNames: ['bleu de chanel', 'bleu', 'chanel bleu', 'blue chanel'],
        productNumber: '252',
        variantId: 52698254327919, // 30ml variant
        expectedTitle: 'No. 252 - Inspired by Bleu de Chanel',
        imageUrl: 'https://magicperfume.co.uk/cdn/shop/files/252M_c.webp?v=1771765712&width=1200',
        url: 'https://magicperfume.co.uk/products/magic-perfume-no-252m',
        price: 999
      }
    ];
    
    const perfumeLower = perfume.name.toLowerCase();
    
    // Check hardcoded mappings first
    for (const mapping of hardcodedMappings) {
      for (const catalogName of mapping.catalogNames) {
        if (perfumeLower.includes(catalogName)) {
          console.log(`🎯 Hardcoded match for "${catalogName}" -> Product #${mapping.productNumber}`);
          
          // First try to find existing product
          let match = fcProducts.find(p => {
            const pNumber = extractProductNumber(p.title);
            return pNumber === mapping.productNumber;
          });
          
          if (match) {
            console.log(`✅ Found existing product:`, match.title);
            return match;
          }
          
          // If not found, create a temporary product with the correct data
          console.log(`⚠️ Creating temporary product for #${mapping.productNumber}`);
          
          return {
            id: `temp-${mapping.productNumber}`,
            title: mapping.expectedTitle,
            image: mapping.imageUrl,
            url: mapping.url,
            variant: mapping.variantId,
            variantSKU: `${mapping.productNumber}${mapping.productNumber === '252' ? 'm' : 'w'}03`,
            price: mapping.price,
            description: mapping.expectedTitle
          };
        }
      }
    }
    
    // If no hardcoded match, try number-based search
    if (perfume.productNumbers && perfume.productNumbers.length > 0) {
      for (const num of perfume.productNumbers) {
        const match = fcProducts.find(p => {
          const pNumber = extractProductNumber(p.title);
          return pNumber === num;
        });
        if (match) {
          console.log(`✅ Found by product number ${num}:`, match.title);
          return match;
        }
      }
    }
    
    console.log('❌ No match found for:', perfume.name);
    return null;
  }

  // ===== RENDER PRODUCT CARD WITH NUMERIC VARIANT ID =====
  function renderProductCard(product, badge) {
    const priceFormatted = product.price ? '£' + (product.price / 100).toFixed(2) : '£19.99';
    
    let displayNumber = '';
    let displayName = product.title;
    
    const numberMatch = product.title.match(/No\.?\s*(\d+)/i);
    if (numberMatch) {
      displayNumber = numberMatch[0];
    }
    
    const inspiredMatch = product.title.match(/Inspired by (.*)/i);
    if (inspiredMatch) {
      displayName = inspiredMatch[1];
    }
    
    // Use the numeric variant ID (NOT the SKU)
    const variantId = product.variant;
    
    return `
      <div class="fc-product-card">
        <div class="fc-badge">${badge}</div>
        <div class="fc-product-inner">
          <img class="fc-product-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div class="fc-product-title">${displayNumber ? displayNumber + ' - ' : ''}${displayName}</div>
          <div class="fc-product-price">${priceFormatted}</div>
          <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart(${variantId})">Add to Cart</button>
          <div>
            <span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${product.url}')">View Details</span>
          </div>
        </div>
      </div>
    `;
  }

  // ===== RENDER YOUR PRODUCT CARD (ALIAS) =====
  function renderYourProductCard(product, badge) {
    return renderProductCard(product, badge);
  }

  // ===== INITIALIZE YOUR SHOPIFY PRODUCTS WITH CORRECT VARIANT IDS AND IMAGES =====
  function fcInitProducts() {
    fcProducts = [
      {% for product in collections.all.products %}
        {
          id: {{ product.id | json }},
          title: {{ product.title | json }},
          image: {{ product.featured_image | img_url: '400x' | json }},
          url: {{ product.url | json }},
          variant: {{ product.variants.first.id | json }},
          variantSKU: {{ product.variants.first.sku | json }},
          price: {{ product.price | json }},
          comparePrice: {{ product.compare_at_price | json }},
          description: {{ product.description | strip_html | json }},
          metafields: {
            perfume: {
              top_notes: {{ product.metafields.perfume.top_notes | default: '' | json }},
              middle_notes: {{ product.metafields.perfume.middle_notes | default: '' | json }},
              base_notes: {{ product.metafields.perfume.base_notes | default: '' | json }}
            },
            custom: {
              top_notes: {{ product.metafields.custom.top_notes | default: '' | json }},
              middle_notes: {{ product.metafields.custom.middle_notes | default: '' | json }},
              base_notes: {{ product.metafields.custom.base_notes | default: '' | json }},
              nuta: {{ product.metafields.custom.nuta | default: '' | json }}
            }
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
    
    console.log('✓ Loaded', fcProducts.length, 'products from Shopify');
    
    // Log all product numbers for debugging
    console.log('📋 Product numbers in fcProducts:');
    fcProducts.forEach(p => {
      const number = extractProductNumber(p.title);
      console.log(`   ${p.title} -> Number: ${number}, Variant ID: ${p.variant}`);
    });
    
    // ===== MANUALLY ADD MISSING PRODUCTS WITH CORRECT VARIANT IDS AND IMAGES =====
    
    // Check for No. 457
    const no457 = fcProducts.find(p => {
      const number = extractProductNumber(p.title);
      return number === '457';
    });
    
    if (!no457) {
      console.log('⚠️ No. 457 NOT FOUND in products! Adding manually with correct data...');
      fcProducts.push({
        id: 'manual-457',
        title: 'No. 457 - Inspired by Musc Noir For Her',
        image: 'https://magicperfume.co.uk/cdn/shop/files/457W_c.webp?v=1771765712&width=1200',
        url: 'https://magicperfume.co.uk/products/magic-perfume-no-457w',
        variant: 52698256146799, // 30ml variant ID
        variantSKU: '457w03',
        price: 999,
        comparePrice: 1999,
        description: 'Inspired by Musc Noir For Her'
      });
      console.log('✅ Manually added No. 457 with correct image and variant ID: 52698256146799');
    } else {
      console.log('✅ No. 457 found:', no457.title, 'Variant ID:', no457.variant);
    }
    
    // Check for No. 077
    const no077 = fcProducts.find(p => {
      const number = extractProductNumber(p.title);
      return number === '077';
    });
    
    if (!no077) {
      console.log('⚠️ No. 077 NOT FOUND! Adding manually...');
      fcProducts.push({
        id: 'manual-077',
        title: 'No. 077 - Inspired by No. 5',
        image: 'https://magicperfume.co.uk/cdn/shop/files/077W_c.webp?v=1771765712&width=1200',
        url: 'https://magicperfume.co.uk/products/magic-perfume-no-077w',
        variant: 52698252493167, // 30ml variant ID for No. 077
        variantSKU: '077w03',
        price: 999,
        comparePrice: 1999,
        description: 'Inspired by No. 5'
      });
      console.log('✅ Manually added No. 077 with variant ID: 52698252493167');
    }
    
    // Check for No. 252
    const no252 = fcProducts.find(p => {
      const number = extractProductNumber(p.title);
      return number === '252';
    });
    
    if (!no252) {
      console.log('⚠️ No. 252 NOT FOUND! Adding manually...');
      fcProducts.push({
        id: 'manual-252',
        title: 'No. 252 - Inspired by Bleu de Chanel',
        image: 'https://magicperfume.co.uk/cdn/shop/files/252M_c.webp?v=1771765712&width=1200',
        url: 'https://magicperfume.co.uk/products/magic-perfume-no-252m',
        variant: 52698254327919, // 30ml variant ID for No. 252
        variantSKU: '252m03',
        price: 999,
        comparePrice: 1999,
        description: 'Inspired by Bleu de Chanel'
      });
      console.log('✅ Manually added No. 252 with variant ID: 52698254327919');
    }
    
    console.log('✓ Final product count after manual additions:', fcProducts.length);
  }

  // ===== SHOW NOTIFICATION =====
  function showNotification(message) {
    let notification = document.querySelector('.fc-notification');
    if (!notification) {
      notification = document.createElement('div');
      notification.className = 'fc-notification';
      document.body.appendChild(notification);
    }
    
    notification.textContent = message;
    notification.classList.add('show');
    
    setTimeout(() => {
      notification.classList.remove('show');
    }, 2000);
  }

  // ===== UPDATE OFFER DISPLAY =====
  function updateOfferDisplay(itemCount) {
    if (!offerStatus || !offerProgress || !offerMessage || !offerSubtext) return;
    
    const percentage = Math.min((itemCount / 3) * 100, 100);
    offerProgress.style.width = percentage + '%';
    
    if (itemCount >= 3) {
      offerStatus.textContent = '🎉 FREE!';
      offerSubtext.textContent = 'You qualify for a free gift!';
      offerMessage.textContent = '🎉 You qualify for a FREE gift!';
      offerBanner.classList.add('qualified');
    } else {
      const needed = 3 - itemCount;
      offerStatus.textContent = `${itemCount}/3`;
      offerSubtext.textContent = `Add ${needed} more for a free gift`;
      offerMessage.textContent = `Add ${needed} more item${needed > 1 ? 's' : ''} to get a free gift`;
      offerBanner.classList.remove('qualified');
    }
  }

  // ===== TOGGLE POPUP =====
  window.fcToggleSearch = function() {
    if (searchPopup.classList.contains('active')) {
      searchPopup.classList.remove('active');
    } else {
      searchPopup.classList.add('active');
      searchInput.focus();
      fetchCartAndUpdate();
    }
  };

  // ===== FETCH CART AND UPDATE COUNT =====
  function fetchCartAndUpdate() {
    return fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        document.querySelectorAll('.cart-count, [data-cart-count]').forEach(el => {
          if (el) el.textContent = cart.item_count;
        });
        updateOfferDisplay(cart.item_count);
        return cart;
      })
      .catch(error => {
        console.error('Error fetching cart:', error);
        return { item_count: 0 };
      });
  }

  // ===== ADD TO CART - MODIFIED TO NOT CLOSE POPUP =====
  window.fcAddToCart = function(variantId) {
    const btn = event.target;
    const originalText = btn.innerText;
    const originalBackground = btn.style.background;
    
    btn.innerText = 'Adding...';
    btn.disabled = true;
    
    console.log('Adding to cart with variant:', variantId);
    
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ 
        id: variantId, 
        quantity: 1 
      })
    })
    .then(response => response.json())
    .then(data => {
      btn.innerText = '✓ Added!';
      btn.style.background = '#2E7D32';
      
      fetchCartAndUpdate().then(cart => {
        showNotification(`✓ Added! ${cart.item_count}/3 items for free gift`);
      });
      
      setTimeout(() => {
        btn.innerText = originalText;
        btn.style.background = originalBackground || '#C41E3A';
        btn.disabled = false;
      }, 2000);
    })
    .catch(error => {
      console.error('Error adding to cart:', error);
      btn.innerText = 'Error';
      btn.style.background = '#c62828';
      
      setTimeout(() => {
        btn.innerText = originalText;
        btn.style.background = originalBackground || '#C41E3A';
        btn.disabled = false;
      }, 1500);
    });
    
    // IMPORTANT: Prevent event propagation to keep popup open
    event.stopPropagation();
    return false;
  };

  // ===== VIEW DETAILS =====
  window.fcViewDetails = function(url) {
    window.location.href = url;
  };

  // ===== GO BACK =====
  window.fcGoBack = function() {
    currentView = 'search';
    if (currentSearchQuery.length >= 1) {
      performSearch(currentSearchQuery);
    } else {
      steps.style.display = 'block';
      content.innerHTML = '';
    }
  };

  // ===== PERFORM SEARCH =====
  function performSearch(query) {
    currentSearchQuery = query;
    content.innerHTML = '<div class="fc-loading">Searching...</div>';
    
    setTimeout(() => {
      // Search in catalog
      const catalogResults = simpleCatalogSearch(query);
      
      // Search in your products
      const yourResults = searchProducts(query);
      
      let html = '';
      
      // Show catalog results
      if (catalogResults.length > 0) {
        html += renderCatalogPerfumes(catalogResults, query);
      }
      
      // Show your products
      if (yourResults.length > 0) {
        html += `<div class="fc-section-title">Our Products (${yourResults.length})</div>`;
        
        yourResults.slice(0, 6).forEach(match => {
          const p = match.product;
          const priceFormatted = p.price ? '£' + (p.price / 100).toFixed(2) : '£9.99';
          
          html += `
            <div class="fc-real-perfume-item" onclick="window.fcViewDetails('${p.url}')">
              <img class="fc-real-perfume-image" src="${p.image}" alt="${p.title}" loading="lazy">
              <div class="fc-real-perfume-info">
                <div class="fc-real-perfume-name">${p.title}</div>
                <div class="fc-real-perfume-year">${priceFormatted}</div>
              </div>
            </div>
          `;
        });
      }
      
      // If no results, show suggestions
      if (catalogResults.length === 0 && yourResults.length === 0) {
        html = '<div class="fc-no-results">No products found for "' + query + '"</div>';
        html += renderSuggestions();
      }
      
      content.innerHTML = html;
    }, 300);
  }

  // ===== SEARCH HANDLER =====
  function fcHandleSearch() {
    const query = searchInput.value.trim();
    
    if (query.length < 1) {
      if (currentView !== 'detail') {
        steps.style.display = 'block';
        content.innerHTML = '';
      }
      return;
    }
    
    steps.style.display = 'none';
    currentView = 'search';
    
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => performSearch(query), 300);
  }

  // ===== INITIALIZE =====
  document.addEventListener('DOMContentLoaded', function() {
    fcInitProducts();
    combineCatalogs();
    searchInput.addEventListener('keyup', fcHandleSearch);
    
    clearSearch.addEventListener('click', function() {
      searchInput.value = '';
      searchInput.focus();
      steps.style.display = 'block';
      content.innerHTML = '';
      currentView = 'search';
    });
    
    setTimeout(fetchCartAndUpdate, 500);
    
    document.addEventListener('click', function(event) {
      if (!searchPopup.contains(event.target) && !stickyButton.contains(event.target) && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    searchPopup.addEventListener('click', function(e) {
      e.stopPropagation();
    });
  });

})(); 
</script>