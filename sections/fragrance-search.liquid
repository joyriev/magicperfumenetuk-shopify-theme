<script>
(function() {
  // ===== YOUR SHOPIFY PRODUCTS =====
  let fcProducts = [];
  let currentView = 'search';
  let currentSearchQuery = '';
  
  // Debounce timer
  let searchTimer = null;
  let autocompleteTimer = null;

  // Get elements
  const stickyButton = document.getElementById('fcStickyButton');
  const searchPopup = document.getElementById('fcSearchPopup');
  const searchInput = document.getElementById('fcSearchInput');
  const clearSearch = document.getElementById('fcClearSearch');
  const steps = document.getElementById('fcSteps');
  const content = document.getElementById('fcContent');
  const autocomplete = document.getElementById('fcAutocomplete');
  
  // Offer elements
  const offerBanner = document.getElementById('fcOfferBanner');
  const offerStatus = document.getElementById('fcOfferStatus');
  const offerProgress = document.getElementById('fcOfferProgress');
  const offerMessage = document.getElementById('fcOfferMessage');
  const offerSubtext = document.getElementById('fcOfferSubtext');

  // ===== COMBINE ALL PERFUME CATALOGS =====
  let allPerfumes = [];

  function combineCatalogs() {
    allPerfumes = [];
    
    // Add from PerfumeCatalog if it exists
    if (window.PerfumeCatalog) {
      for (let brandKey in window.PerfumeCatalog) {
        if (Array.isArray(window.PerfumeCatalog[brandKey])) {
          allPerfumes.push(...window.PerfumeCatalog[brandKey]);
        }
      }
    }
    
    console.log(`✓ Combined catalog: ${allPerfumes.length} perfumes`);
  }

  // ===== ADVANCED FUZZY SEARCH FUNCTION (Levenshtein distance) =====
  function getLevenshteinDistance(a, b) {
    if (a.length === 0) return b.length;
    if (b.length === 0) return a.length;
    const matrix = [];
    for (let i = 0; i <= b.length; i++) matrix[i] = [i];
    for (let j = 0; j <= a.length; j++) matrix[0][j] = j;
    for (let i = 1; i <= b.length; i++) {
      for (let j = 1; j <= a.length; j++) {
        if (b.charAt(i - 1) === a.charAt(j - 1)) {
          matrix[i][j] = matrix[i - 1][j - 1];
        } else {
          matrix[i][j] = Math.min(
            matrix[i - 1][j - 1] + 1,
            matrix[i][j - 1] + 1,
            matrix[i - 1][j] + 1
          );
        }
      }
    }
    return matrix[b.length][a.length];
  }

  function getSimilarityScore(str1, str2) {
    if (!str1 || !str2) return 0;
    const s1 = String(str1).toLowerCase().trim();
    const s2 = String(str2).toLowerCase().trim();
    if (s1 === s2) return 1;
    if (s1.includes(s2) || s2.includes(s1)) return 0.9;
    const distance = getLevenshteinDistance(s1, s2);
    const maxLength = Math.max(s1.length, s2.length);
    return 1 - (distance / maxLength);
  }

  // ===== GET ALL SEARCHABLE TEXT FROM A PRODUCT =====
  function getProductSearchableText(product) {
    const title = (product.title || '').toLowerCase();
    const topNotes = (product.topNotes || '').toLowerCase();
    const middleNotes = (product.middleNotes || '').toLowerCase();
    const baseNotes = (product.baseNotes || '').toLowerCase();
    const composition = (product.fragranceComposition || '').toLowerCase();
    const description = (product.description || '').toLowerCase();
    
    return `${title} ${topNotes} ${middleNotes} ${baseNotes} ${composition} ${description}`;
  }

  // ===== GET ALL SEARCHABLE TEXT FROM CATALOG PERFUME =====
  function getCatalogSearchableText(perfume) {
    const name = (perfume.name || '').toLowerCase();
    const brand = (perfume.brand || '').toLowerCase();
    const topNotes = (perfume.top_notes || []).join(' ').toLowerCase();
    const heartNotes = (perfume.heart_notes || []).join(' ').toLowerCase();
    const baseNotes = (perfume.base_notes || []).join(' ').toLowerCase();
    const description = (perfume.description || '').toLowerCase();
    
    return `${name} ${brand} ${topNotes} ${heartNotes} ${baseNotes} ${description}`;
  }

  // ===== ENHANCED NOTE MATCHING FOR PRODUCTS =====
  function matchProductNotes(catalogPerfume, product) {
    // Get all catalog notes
    const catalogTopNotes = (catalogPerfume.top_notes || []).map(n => n.toLowerCase().trim());
    const catalogHeartNotes = (catalogPerfume.heart_notes || []).map(n => n.toLowerCase().trim());
    const catalogBaseNotes = (catalogPerfume.base_notes || []).map(n => n.toLowerCase().trim());
    const allCatalogNotes = [...catalogTopNotes, ...catalogHeartNotes, ...catalogBaseNotes];
    
    // Get all product notes
    const productTopNotes = (product.topNotes || '').toLowerCase().split(',').map(n => n.trim()).filter(n => n);
    const productMiddleNotes = (product.middleNotes || '').toLowerCase().split(',').map(n => n.trim()).filter(n => n);
    const productBaseNotes = (product.baseNotes || '').toLowerCase().split(',').map(n => n.trim()).filter(n => n);
    const allProductNotes = [...productTopNotes, ...productMiddleNotes, ...productBaseNotes];
    
    let matchScore = 0;
    let matchedNotes = [];
    
    // Match each catalog note against product notes
    allCatalogNotes.forEach(catalogNote => {
      allProductNotes.forEach(productNote => {
        // Exact match
        if (productNote === catalogNote) {
          matchScore += 50;
          matchedNotes.push(catalogNote);
        }
        // Partial match (e.g., "vanilla" matches "madagascar vanilla")
        else if (productNote.includes(catalogNote) || catalogNote.includes(productNote)) {
          if (productNote.length > 2 && catalogNote.length > 2) {
            matchScore += 25;
            matchedNotes.push(catalogNote);
          }
        }
        // Fuzzy match for typos
        else {
          const similarity = getSimilarityScore(productNote, catalogNote);
          if (similarity > 0.7) {
            matchScore += similarity * 20;
            matchedNotes.push(catalogNote);
          }
        }
      });
    });
    
    // Match fragrance composition text
    const productComposition = (product.fragranceComposition || '').toLowerCase();
    const catalogDesc = (catalogPerfume.description || '').toLowerCase();
    
    // Common fragrance keywords
    const keywords = [
      'floral', 'citrus', 'woody', 'oriental', 'fresh', 'sweet', 'spicy', 
      'fruity', 'green', 'aquatic', 'powdery', 'creamy', 'warm', 'clean',
      'rose', 'jasmine', 'vanilla', 'musk', 'amber', 'patchouli', 'sandalwood'
    ];
    
    keywords.forEach(keyword => {
      if (catalogDesc.includes(keyword) && productComposition.includes(keyword)) {
        matchScore += 15;
      }
    });
    
    return {
      score: matchScore,
      matchedNotes: [...new Set(matchedNotes)]
    };
  }

