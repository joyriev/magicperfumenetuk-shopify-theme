  // ===== 3. ULTIMATE TEXT NORMALIZATION =====
  function normalizeTextUltimate(text) {
    if (!text) return '';
    
    let normalized = text.toLowerCase();
    
    // Step 1: Replace all accented characters with their base
    for (const [base, variations] of Object.entries(charMap)) {
      for (const variant of variations) {
        // Skip if it's the space mapping (handled separately)
        if (base === ' ') continue;
        
        // Use regex to replace all occurrences
        const regex = new RegExp(variant, 'g');
        normalized = normalized.replace(regex, base);
      }
    }
    
    // Step 2: Replace all special characters and punctuation with spaces
    // This handles commas, periods, dashes, etc.
    normalized = normalized
      // Replace apostrophes and quotes with a special marker first
      .replace(/[''´`''′‵՚ꞌꞋ]/g, "'")
      // Replace other punctuation with spaces
      .replace(/[,".!?;:\-()\[\]{}<>@#$%^&*+=|\\~`]/g, ' ')
      // Replace multiple spaces with single space
      .replace(/\s+/g, ' ')
      .trim();
    
    return normalized;
  }

  // ===== 4. LEVENSHTEIN DISTANCE FOR FUZZY MATCHING =====
  function levenshteinDistance(s1, s2) {
    const len1 = s1.length;
    const len2 = s2.length;
    const matrix = Array(len2 + 1).fill(null).map(() => Array(len1 + 1).fill(0));
    
    for (let i = 0; i <= len1; i++) matrix[0][i] = i;
    for (let j = 0; j <= len2; j++) matrix[j][0] = j;
    
    for (let j = 1; j <= len2; j++) {
      for (let i = 1; i <= len1; i++) {
        const indicator = s1[i - 1] === s2[j - 1] ? 0 : 1;
        matrix[j][i] = Math.min(
          matrix[j][i - 1] + 1,
          matrix[j - 1][i] + 1,
          matrix[j - 1][i - 1] + indicator
        );
      }
    }
    
    return matrix[len2][len1];
  }

  // ===== DAMERAU-LEVENSHTEIN DISTANCE (allows transpositions) =====
  function damerauLevenshteinDistance(s1, s2) {
    const len1 = s1.length;
    const len2 = s2.length;
    const matrix = Array(len2 + 1).fill(null).map(() => Array(len1 + 1).fill(0));
    
    for (let i = 0; i <= len1; i++) matrix[0][i] = i;
    for (let j = 0; j <= len2; j++) matrix[j][0] = j;
    
    for (let j = 1; j <= len2; j++) {
      for (let i = 1; i <= len1; i++) {
        const cost = s1[i - 1] === s2[j - 1] ? 0 : 1;
        matrix[j][i] = Math.min(
          matrix[j][i - 1] + 1,      // insertion
          matrix[j - 1][i] + 1,      // deletion
          matrix[j - 1][i - 1] + cost // substitution
        );
        
        // Transposition
        if (i > 1 && j > 1 && s1[i - 1] === s2[j - 2] && s1[i - 2] === s2[j - 1]) {
          matrix[j][i] = Math.min(matrix[j][i], matrix[j - 2][i - 2] + cost);
        }
      }
    }
    
    return matrix[len2][len1];
  }

  // ===== ADVANCED FUZZY SIMILARITY SCORE (OPTIMIZED) =====
  function getAdvancedFuzzySimilarity(query, text) {
    // Quick checks first
    const q = query.toLowerCase();
    const t = text.toLowerCase();
    
    // Exact match
    if (q === t) return 100;
    
    // Direct contains (fast)
    if (t.includes(q) || q.includes(t)) return 90;
    
    // Only do expensive Levenshtein for longer strings
    if (q.length < 3 || t.length < 3) return 0;
    
    const lDistance = levenshteinDistance(q, t);
    const maxLen = Math.max(q.length, t.length);
    return maxLen > 0 ? ((maxLen - lDistance) / maxLen) * 100 : 0;
  }

  // ===== BIDIRECTIONAL FUZZY MATCH (OPTIMIZED) =====
  function getBidirectionalFuzzyScore(query, text) {
    // Quick exact/contains check first
    const q = query.toLowerCase();
    const t = text.toLowerCase();
    
    if (q === t) return 100;
    if (t.includes(q) || q.includes(t)) return 90;
    
    // Only calculate fuzzy if strings are similar length
    if (Math.abs(q.length - t.length) > 5) return 0;
    
    // Single fuzzy calculation instead of bidirectional
    const similarity = getAdvancedFuzzySimilarity(q, t);
    return similarity;
  }

  // ===== COMPOUND WORD MATCHING (brand+name without spaces) =====
  function matchCompoundWords(query, ...textParts) {
    const allCombinations = [
      textParts.join(''),           // No spaces
      textParts.join(' '),          // With spaces
      textParts.reverse().join(''), // Reversed, no spaces
      textParts.reverse().join(' ')  // Reversed, with spaces
    ];
    
    let bestScore = 0;
    for (const combo of allCombinations) {
      const score = getBidirectionalFuzzyScore(query, combo);
      bestScore = Math.max(bestScore, score);
    }
    
    return bestScore;
  }

  // ===== 5. HANDLE APOSTROPHES SPECIFICALLY =====
  function handleApostrophes(text) {
    // Create multiple versions with and without apostrophes
    const versions = new Set();
    
    // Original
    versions.add(text);
    
    // Without apostrophes
    versions.add(text.replace(/'/g, ''));
    
    // With space instead of apostrophe
    versions.add(text.replace(/'/g, ' '));
    
    // Without any punctuation
    versions.add(text.replace(/[^a-z0-9]/gi, ''));
    
    return Array.from(versions);
  }

  // ===== 6. CREATE SEARCH VARIANTS FOR A QUERY (OPTIMIZED) =====
  function createSearchVariants(query) {
    const variants = new Set();
    const original = query.toLowerCase().trim();
    
    // Add original
    variants.add(original);
    
    // Add normalized version
    const normalized = normalizeTextUltimate(original);
    variants.add(normalized);
    
    // Split into words and add combinations
    const words = normalized.split(' ').filter(w => w.length > 0);
    
    // Add individual words (LIMITED)
    words.slice(0, 3).forEach(word => variants.add(word)); // Max 3 words
    
    // Add words combined (no spaces) - CRITICAL FOR BRAND+NAME MATCHING
    if (words.length > 1) {
      variants.add(words.join(''));              // diormen → diormen
      variants.add([...words].reverse().join(''));  // Reversed order
    }
    
    // Handle numbers
    if (/\d+/.test(original)) {
      const numbers = original.match(/\d+/g);
      if (numbers) {
        numbers.forEach(num => variants.add(num));
      }
    }
    
    // Limit total variants to prevent performance issues
    const variantArray = Array.from(variants).filter(v => v.length >= 1);
    return variantArray.slice(0, 30); // Max 30 variants
  }

  // ===== 7. CREATE PRODUCT SEARCH TEXT =====
  function createProductSearchText(product) {
    const texts = [];
    
    // Title (with and without special characters)
    texts.push(normalizeTextUltimate(product.title));
    texts.push(product.title.toLowerCase().replace(/[^a-z0-9]/gi, ''));
    
    // Brand
    texts.push(normalizeTextUltimate(product.brand));
    texts.push(product.brand.toLowerCase().replace(/[^a-z0-9]/gi, ''));
    
    // COMPOUND WORDS: Brand + Name combinations (no spaces, no commas)
    const brandNormalized = normalizeTextUltimate(product.brand);
    const titleNormalized = normalizeTextUltimate(product.title);
    const titleWords = titleNormalized.split(' ').filter(w => w.length > 0);
    
    if (titleWords.length > 0) {
      // Brand + first word of product
      texts.push(brandNormalized + titleWords[0]);
      texts.push(titleWords[0] + brandNormalized);
      
      // Brand + full product name (first 2 words)
      if (titleWords.length > 1) {
        texts.push(brandNormalized + titleWords.slice(0, 2).join(''));
        texts.push(titleWords.slice(0, 2).join('') + brandNormalized);
      }
    }
    
    // Number
    if (product.number) {
      texts.push(product.number);
      texts.push(product.number.replace(/^0+/, '')); // Remove leading zeros
    }
    
    // Search terms
    if (product.searchTerms) {
      product.searchTerms.forEach(term => {
        texts.push(normalizeTextUltimate(term));
        texts.push(term.toLowerCase().replace(/[^a-z0-9]/gi, ''));
      });
    }
    
    // Create normalized versions
    return texts.map(t => normalizeTextUltimate(t)).filter(t => t.length > 0);
  }

  // ===== 8. ENHANCED FUZZY SEARCH (OPTIMIZED) =====
  function enhancedFuzzySearch(query) {
    if (!query || query.length < 1) return [];
    
    const searchVariants = createSearchVariants(query);
    const results = [];
    const addedIds = new Set();
    
    hardcodedProducts.forEach(product => {
      const productTexts = createProductSearchText(product);
      let bestScore = 0;
      
      // Early exit if score is already perfect
      if (bestScore >= 100) return;
      
      // Number match (fast, high priority)
      if (product.number) {
        if (searchVariants.includes(product.number) || searchVariants.includes(product.number.replace(/^0+/, ''))) {
          bestScore = 95;
        }
      }
      
      // Check each variant against each product text
      for (const variant of searchVariants) {
        if (bestScore >= 95) break; // Early exit if high score
        if (variant.length < 1) continue;
        
        for (const productText of productTexts) {
          if (!productText) continue;
          
          // Exact match (highest score)
          if (productText === variant) {
            bestScore = 100;
            break;
          }
          
          // Fast contains match
          if (productText.includes(variant) || variant.includes(productText)) {
            bestScore = Math.max(bestScore, 90);
          }
          // Only do fuzzy matching on promising candidates
          else if (bestScore < 85 && variant.length >= 2 && productText.length >= 2) {
            const fuzzyScore = getAdvancedFuzzySimilarity(variant, productText);
            if (fuzzyScore > 65) {
              bestScore = Math.max(bestScore, fuzzyScore);
            }
          }
        }
        if (bestScore >= 95) break;
      }
      
      // Brand match (only if not already matched)
      if (bestScore < 85) {
        const brandNorm = normalizeTextUltimate(product.brand);
        if (brandNorm.length > 0 && searchVariants[0]) {
          const brandScore = getAdvancedFuzzySimilarity(searchVariants[0], brandNorm);
          if (brandScore > 70) {
            bestScore = Math.max(bestScore, brandScore);
          }
        }
      }
      
      // Include if score is reasonable
      if (bestScore > 20 && !addedIds.has(product.id)) {
        results.push({
          product,
          score: bestScore
        });
        addedIds.add(product.id);
      }
    });
    
    return results.sort((a, b) => b.score - a.score);
  }

