  // ===== GET SHOPIFY PRODUCT BY PERFUME ID =====
  function getShopifyProductByPerfumeId(perfumeId) {
    if (!window.PerfumeCatalog) return null;
    
    for (let brandKey in window.PerfumeCatalog) {
      if (Array.isArray(window.PerfumeCatalog[brandKey])) {
