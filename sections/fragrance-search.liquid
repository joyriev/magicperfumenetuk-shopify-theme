          return perfume.shopifyProduct;
        }
      }
    }
    return null;
  }

  // ===== FIND SHOPIFY PRODUCT BY MAPPED PRODUCT - ENHANCED VERSION =====
  function findShopifyProductByMappedProduct(mappedProduct) {
    if (!mappedProduct || !mappedProduct.title) return null;
    
    console.log('Looking for Shopify product matching:', mappedProduct.title);
    
    // SPECIAL CASE HANDLING for known products
    const specialCases = {
      'No. 077 - Inspired by No. 5': '077',
      'No. 457 - Inspired by Musc Noir For Her': '457',
      'No. 252 - Inspired by Bleu de Chanel': '252',
      'No. 260 - Inspired by Code': '260',
      'No. 135 - Inspired by Armani Code for Women': '135',
      'No. 067 - Inspired by Coco Mademoiselle': '067',
      'No. 079 - Inspired by Coco': '079',
      'No. 006 - Inspired by Chance': '006',
      'No. 222 - Inspired by Allure Homme Sport': '222',
      'No. 277 - Inspired by Dior Homme Intense': '277',
      'No. 211 - Inspired by Dior Homme': '211',
      'No. 338 - Inspired by Sauvage Parfum': '338',
      'No. 366 - Inspired by Sauvage Elixir': '366',
      'No. 206 - Inspired by Fahrenheit': '206',
      'No. 350 - Inspired by Fahrenheit Le Parfum': '350',
      'No. 159 - Inspired by J\'Adore': '159',
      'No. 145 - Inspired by Hypnotic Poison': '145',
      'No. 196 - Inspired by Dior Homme Parfum': '196',
      'No. 082 - Inspired by Miss Cherie': '082'
    };
    
    // Check special cases first
    if (specialCases[mappedProduct.title]) {
      const productNumber = specialCases[mappedProduct.title];
      console.log('Special case match for:', mappedProduct.title, 'with number:', productNumber);
      
      const match = fcProducts.find(p => {
        const pNumber = extractProductNumber(p.title);
        return pNumber === productNumber;
      });
      
      if (match) {
        console.log('Found special case match:', match.title);
        return match;
      }
    }
    
    // Method 1: Extract product number from mapped product title
    const productNumber = extractProductNumber(mappedProduct.title);
    
    if (productNumber) {
      console.log('Extracted product number:', productNumber);
      
      // Find by product number in title
      const match = fcProducts.find(p => {
        const pNumber = extractProductNumber(p.title);
        return pNumber === productNumber;
      });
      
      if (match) {
        console.log('Found match by number:', match.title);
        return match;
      }
    }
    
    // Method 2: Try exact title match
    const exactMatch = fcProducts.find(p => p.title === mappedProduct.title);
    if (exactMatch) {
      console.log('Found exact title match:', exactMatch.title);
      return exactMatch;
    }
    
    // Method 3: Try to match by URL
    if (mappedProduct.url) {
      const urlSlug = mappedProduct.url.split('/').pop();
      const match = fcProducts.find(p => p.url.includes(urlSlug));
      if (match) {
        console.log('Found match by URL:', match.title);
        return match;
      }
    }
    
    // Method 4: Try partial title match
    const partialMatch = fcProducts.find(p => {
      const pTitle = p.title.toLowerCase();
      const mTitle = mappedProduct.title.toLowerCase();
      return pTitle.includes(mTitle) || mTitle.includes(pTitle);
    });
    
    if (partialMatch) {
      console.log('Found match by partial title:', partialMatch.title);
      return partialMatch;
    }
    
    console.log('No match found for:', mappedProduct.title);
    return null;
  }

