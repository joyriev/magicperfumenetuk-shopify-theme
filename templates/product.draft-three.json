            "rating": 5,
            "show_verified_badge": true,
            "product": ""
          }
        },
        "review_U7Tp4f": {
          "type": "review",
          "settings": {
            "content": "<p>Adoooro questi profumi!!! Ogni singolo che ho ricevuto odora divinamente. Alcuni direi che sono persino migliori dell'originale.</p>",
