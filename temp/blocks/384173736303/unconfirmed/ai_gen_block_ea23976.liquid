</product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.filterSelect = this.querySelector('.ai-product-grid-filter-select-{{ ai_gen_id }}');
        this.productItems = this.querySelectorAll('.ai-product-grid-item-{{ ai_gen_id }}');
        this.countText = this.querySelector('.ai-product-grid-count-text-{{ ai_gen_id }}');
        this.totalProducts = this.productItems.length;
        
        this.modal = this.querySelector('.ai-product-grid-modal-{{ ai_gen_id }}');
        this.modalClose = this.querySelector('.ai-product-grid-modal-close-{{ ai_gen_id }}');
        this.currentProduct = null;
        this.selectedVariant = null;
        
        if (this.filterSelect) {
          this.setupFilter();
        }

        this.setupQuickAdd();
        this.setupModal();
      }

      setupFilter() {
        this.filterSelect.addEventListener('change', (event) => {
          const selectedFilter = event.target.value;
          this.filterProducts(selectedFilter);
        });
      }

      filterProducts(filter) {
        let visibleCount = 0;

        this.productItems.forEach(item => {
          if (filter === 'all') {
            item.classList.remove('hidden');
            visibleCount++;
          } else {
            const tags = item.getAttribute('data-tags');
            if (tags && tags.includes(filter)) {
              item.classList.remove('hidden');
              visibleCount++;
            } else {
              item.classList.add('hidden');
            }
          }
        });

        if (this.countText) {
          const productWord = visibleCount === 1 ? 'product' : 'products';
          this.countText.textContent = visibleCount + ' ' + productWord;
        }
      }

      setupQuickAdd() {
        const forms = this.querySelectorAll('product-form form');
        
        forms.forEach(form => {
          form.addEventListener('submit', (event) => {
            event.preventDefault();
            
            const button = form.querySelector('.ai-product-grid-quick-add-button-{{ ai_gen_id }}');
            const formData = new FormData(form);
            
            this.addToCart(button, formData);
          });
        });

        const chooseOptionsButtons = this.querySelectorAll('.ai-product-grid-choose-options-{{ ai_gen_id }}');
        chooseOptionsButtons.forEach(button => {
          button.addEventListener('click', (event) => {
            event.preventDefault();
            const productUrl = button.getAttribute('data-product-url');
            this.openModal(productUrl);
          });
        });
      }

      setupModal() {
        this.modalClose.addEventListener('click', () => {
          this.closeModal();
        });

        this.modal.addEventListener('click', (event) => {
          if (event.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });

        const quantityMinus = this.modal.querySelector('.ai-product-grid-modal-quantity-minus-{{ ai_gen_id }}');
        const quantityPlus = this.modal.querySelector('.ai-product-grid-modal-quantity-plus-{{ ai_gen_id }}');
        const quantityInput = this.modal.querySelector('.ai-product-grid-modal-quantity-number-{{ ai_gen_id }}');

        quantityMinus.addEventListener('click', () => {
          const currentValue = parseInt(quantityInput.value);
          if (currentValue > 1) {
            quantityInput.value = currentValue - 1;
          }
        });

        quantityPlus.addEventListener('click', () => {
          const currentValue = parseInt(quantityInput.value);
          quantityInput.value = currentValue + 1;
        });

        quantityInput.addEventListener('change', () => {
          if (parseInt(quantityInput.value) < 1) {
            quantityInput.value = 1;
          }
        });
      }

      openModal(productUrl) {
        fetch(productUrl)
          .then(response => response.json())
          .then(product => {
            this.currentProduct = product;
            this.renderModal(product);
            this.modal.classList.add('active');
            document.body.style.overflow = 'hidden';
          })
          .catch(error => {
            console.error('Error loading product:', error);
          });
      }

      closeModal() {
        this.modal.classList.remove('active');
        document.body.style.overflow = '';
        this.currentProduct = null;
        this.selectedVariant = null;
        
        const quantityInput = this.modal.querySelector('.ai-product-grid-modal-quantity-number-{{ ai_gen_id }}');
        quantityInput.value = 1;
      }

      renderModal(product) {
        const modalImage = this.modal.querySelector('.ai-product-grid-modal-main-image-{{ ai_gen_id }}');
        const modalVendor = this.modal.querySelector('.ai-product-grid-modal-vendor-{{ ai_gen_id }}');
        const modalTitle = this.modal.querySelector('.ai-product-grid-modal-title-{{ ai_gen_id }}');
        const modalPrice = this.modal.querySelector('.ai-product-grid-modal-price-{{ ai_gen_id }}');
        const modalComparePrice = this.modal.querySelector('.ai-product-grid-modal-compare-price-{{ ai_gen_id }}');
        const modalSku = this.modal.querySelector('.ai-product-grid-modal-sku-{{ ai_gen_id }}');
        const modalAvailability = this.modal.querySelector('.ai-product-grid-modal-availability-{{ ai_gen_id }}');
        const modalDescription = this.modal.querySelector('.ai-product-grid-modal-description-{{ ai_gen_id }}');
        const modalVariants = this.modal.querySelector('.ai-product-grid-modal-variants-{{ ai_gen_id }}');
        const modalAddButton = this.modal.querySelector('.ai-product-grid-modal-add-button-{{ ai_gen_id }}');
        const modalViewButton = this.modal.querySelector('.ai-product-grid-modal-view-button-{{ ai_gen_id }}');

        if (product.featured_image) {
          modalImage.innerHTML = '<img src="' + product.featured_image + '" alt="' + product.title + '">';
        }

        if (product.vendor) {
          modalVendor.textContent = product.vendor;
          modalVendor.style.display = 'block';
        } else {
          modalVendor.style.display = 'none';
        }

        modalTitle.textContent = product.title;
        modalViewButton.href = product.url;

        this.selectedVariant = product.variants[0];
        
        if (product.description) {
          modalDescription.innerHTML = product.description;
        } else {
          modalDescription.textContent = '';
        }

        modalVariants.innerHTML = '';
        
        if (product.options && product.options.length > 0 && product.options[0].name !== 'Title') {
          product.options.forEach((option, index) => {
            const optionDiv = document.createElement('div');
            optionDiv.className = 'ai-product-grid-modal-variant-group-{{ ai_gen_id }}';
            
            const label = document.createElement('label');
            label.className = 'ai-product-grid-modal-variant-label-{{ ai_gen_id }}';
            label.innerHTML = '<span>' + option.name + '</span><span class="ai-product-grid-modal-variant-value-{{ ai_gen_id }}">' + option.values[0] + '</span>';
            
            const select = document.createElement('select');
            select.className = 'ai-product-grid-modal-variant-select-{{ ai_gen_id }}';
            select.setAttribute('data-option-index', index);
            
            option.values.forEach(value => {
              const optionElement = document.createElement('option');
              optionElement.value = value;
              optionElement.textContent = value;
              select.appendChild(optionElement);
            });
            
            select.addEventListener('change', (e) => {
              const valueSpan = label.querySelector('.ai-product-grid-modal-variant-value-{{ ai_gen_id }}');
              valueSpan.textContent = e.target.value;
              this.updateSelectedVariant();
            });
            
            optionDiv.appendChild(label);
            optionDiv.appendChild(select);
            modalVariants.appendChild(optionDiv);
          });
        }

        this.updateVariantInfo();

        modalAddButton.onclick = () => {
          if (this.selectedVariant && this.selectedVariant.available) {
            const quantityInput = this.modal.querySelector('.ai-product-grid-modal-quantity-number-{{ ai_gen_id }}');
            const quantity = parseInt(quantityInput.value) || 1;
            
            const formData = new FormData();
            formData.append('id', this.selectedVariant.id);
            formData.append('quantity', quantity);
            
            this.addToCart(modalAddButton, formData);
          }
        };
      }

      updateSelectedVariant() {
        const selects = this.modal.querySelectorAll('.ai-product-grid-modal-variant-select-{{ ai_gen_id }}');
        const selectedOptions = Array.from(selects).map(select => select.value);
        
        this.selectedVariant = this.currentProduct.variants.find(variant => {
          return selectedOptions.every((option, index) => {
            return variant.options[index] === option;
          });
        });

        this.updateVariantInfo();
      }

      updateVariantInfo() {
        const modalPrice = this.modal.querySelector('.ai-product-grid-modal-price-{{ ai_gen_id }}');
        const modalComparePrice = this.modal.querySelector('.ai-product-grid-modal-compare-price-{{ ai_gen_id }}');
        const modalSku = this.modal.querySelector('.ai-product-grid-modal-sku-{{ ai_gen_id }}');
        const modalAvailability = this.modal.querySelector('.ai-product-grid-modal-availability-{{ ai_gen_id }}');
        const modalAddButton = this.modal.querySelector('.ai-product-grid-modal-add-button-{{ ai_gen_id }}');
        const buttonText = modalAddButton.querySelector('.ai-product-grid-button-text-{{ ai_gen_id }}');

        if (this.selectedVariant) {
          const price = (this.selectedVariant.price / 100).toFixed(2);
          modalPrice.textContent = '£' + price;

          if (this.selectedVariant.compare_at_price && this.selectedVariant.compare_at_price > this.selectedVariant.price) {
            const comparePrice = (this.selectedVariant.compare_at_price / 100).toFixed(2);
            modalComparePrice.textContent = '£' + comparePrice;
            modalComparePrice.style.display = 'block';
          } else {
            modalComparePrice.style.display = 'none';
          }

          if (this.selectedVariant.sku) {
            modalSku.textContent = 'SKU: ' + this.selectedVariant.sku;
            modalSku.style.display = 'block';
          } else {
            modalSku.style.display = 'none';
          }

          if (this.selectedVariant.available) {
            modalAvailability.textContent = 'In stock';
            modalAvailability.className = 'ai-product-grid-modal-availability-{{ ai_gen_id }} in-stock';
            modalAddButton.disabled = false;
            buttonText.textContent = 'Add to cart';
          } else {
            modalAvailability.textContent = 'Out of stock';
            modalAvailability.className = 'ai-product-grid-modal-availability-{{ ai_gen_id }} out-of-stock';
            modalAddButton.disabled = true;
            buttonText.textContent = 'Sold out';
          }
        }
      }

      addToCart(button, formData) {
        button.classList.add('loading');
        button.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(data => {
          button.classList.remove('loading');
          button.disabled = false;

          if (window.Shopify && window.Shopify.theme && window.Shopify.theme.cart) {
            window.Shopify.theme.cart.refresh();
          }

          const cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer) {
            cartDrawer.open();
          }

          const cartNotification = document.querySelector('cart-notification');
          if (cartNotification) {
            cartNotification.open();
          }

          document.dispatchEvent(new CustomEvent('cart:item-added', {
            detail: { product: data }
          }));

          this.closeModal();
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
          button.classList.remove('loading');
          button.disabled = false;
        });
      }
    }

    customElements.define('product-grid-{{ ai_gen_id }}', ProductGrid{{ ai_gen_id }});
  })();
</script>

