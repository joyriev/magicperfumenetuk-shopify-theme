            <div class="ai-product-grid-modal-quantity-{{ ai_gen_id }}">
              <label class="ai-product-grid-modal-quantity-label-{{ ai_gen_id }}">Quantity</label>
              <div class="ai-product-grid-modal-quantity-input-{{ ai_gen_id }}">
                <button type="button" class="ai-product-grid-modal-quantity-button-{{ ai_gen_id }} ai-product-grid-modal-quantity-minus-{{ ai_gen_id }}" aria-label="Decrease quantity">−</button>
                <input type="number" class="ai-product-grid-modal-quantity-number-{{ ai_gen_id }}" value="1" min="1" aria-label="Quantity">
                <button type="button" class="ai-product-grid-modal-quantity-button-{{ ai_gen_id }} ai-product-grid-modal-quantity-plus-{{ ai_gen_id }}" aria-label="Increase quantity">+</button>
              </div>
