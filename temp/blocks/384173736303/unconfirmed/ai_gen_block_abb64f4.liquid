      "default": "#000000"
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Price color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Product grid with filters"
    }
  ]
}
{% endschema %}
