{% doc %}
  @prompt
    Create product grid section with filtering using tags and customizable headline + collection
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-product-grid-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-grid-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 32px;
  }

  .ai-product-grid-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-product-grid-filters-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: {{ block.settings.heading_alignment }};
    margin-bottom: 32px;
  }

  .ai-product-grid-filter-btn-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: {{ block.settings.filter_bg_color }};
    color: {{ block.settings.filter_text_color }};
    border: 1px solid {{ block.settings.filter_border_color }};
    border-radius: {{ block.settings.filter_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .ai-product-grid-filter-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.filter_hover_bg_color }};
    color: {{ block.settings.filter_hover_text_color }};
    border-color: {{ block.settings.filter_hover_border_color }};
  }

  .ai-product-grid-filter-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.filter_active_bg_color }};
    color: {{ block.settings.filter_active_text_color }};
    border-color: {{ block.settings.filter_active_border_color }};
  }

  .ai-product-grid-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-product-grid-item-{{ ai_gen_id }} {
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .ai-product-grid-item-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-product-grid-card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_bg_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-product-grid-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-product-grid-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-product-grid-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-grid-info-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-product-grid-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.product_title_color }};
  }

  .ai-product-grid-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.product_price_color }};
    font-weight: 500;
  }

  .ai-product-grid-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-product-grid-empty-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-product-grid-products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid-products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-product-grid-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<product-grid-{{ ai_gen_id }} class="ai-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-product-grid-header-{{ ai_gen_id }}">
        <h2 class="ai-product-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      {% assign collection = block.settings.collection %}
      {% assign all_tags = '' %}
      
      {% for product in collection.products %}
        {% for tag in product.tags %}
          {% unless all_tags contains tag %}
            {% if all_tags == '' %}
              {% assign all_tags = tag %}
            {% else %}
              {% assign all_tags = all_tags | append: ',' | append: tag %}
            {% endif %}
          {% endunless %}
        {% endfor %}
      {% endfor %}

      {% if block.settings.enable_filtering and all_tags != '' %}
        {% assign tags_array = all_tags | split: ',' %}
        <div class="ai-product-grid-filters-{{ ai_gen_id }}">
          <button 
            class="ai-product-grid-filter-btn-{{ ai_gen_id }} active" 
            data-filter="all"
          >
            All
          </button>
          {% for tag in tags_array %}
            <button 
              class="ai-product-grid-filter-btn-{{ ai_gen_id }}" 
              data-filter="{{ tag | handleize }}"
            >
              {{ tag }}
            </button>
          {% endfor %}
        </div>
      {% endif %}

      <div class="ai-product-grid-products-{{ ai_gen_id }}">
        {% for product in collection.products limit: block.settings.products_to_show %}
          {% assign product_tags = '' %}
          {% for tag in product.tags %}
            {% if product_tags == '' %}
              {% assign product_tags = tag | handleize %}
            {% else %}
              {% assign product_tags = product_tags | append: ' ' | append: tag | handleize %}
            {% endif %}
          {% endfor %}

          <div 
            class="ai-product-grid-item-{{ ai_gen_id }}" 
            data-tags="{{ product_tags }}"
          >
            <a href="{{ product.url }}" class="ai-product-grid-card-{{ ai_gen_id }}">
              <div class="ai-product-grid-image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-product-grid-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag }}
                {% endif %}
              </div>
              <div class="ai-product-grid-info-{{ ai_gen_id }}">
                <h3 class="ai-product-grid-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                <div class="ai-product-grid-price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-product-grid-empty-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
        <p>Select a collection to display products</p>
      </div>
    {% endif %}
  </div>
</product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.filterButtons = this.querySelectorAll('.ai-product-grid-filter-btn-{{ ai_gen_id }}');
        this.productItems = this.querySelectorAll('.ai-product-grid-item-{{ ai_gen_id }}');
        
        this.setupFilters();
      }

      setupFilters() {
        this.filterButtons.forEach(button => {
          button.addEventListener('click', () => {
            const filter = button.getAttribute('data-filter');
            
            this.filterButtons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');
            
            this.filterProducts(filter);
          });
        });
      }

      filterProducts(filter) {
        this.productItems.forEach(item => {
          if (filter === 'all') {
            item.classList.remove('hidden');
          } else {
            const tags = item.getAttribute('data-tags');
            if (tags && tags.includes(filter)) {
              item.classList.remove('hidden');
            } else {
              item.classList.add('hidden');
            }
          }
        });
      }
    }

    customElements.define('product-grid-{{ ai_gen_id }}', ProductGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product grid with filters",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 50,
      "step": 2,
      "label": "Products to show",
      "default": 12
    },
    {
      "type": "header",
      "content": "Filtering"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable tag filtering",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns on desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on tablet",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Grid gap",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Filter buttons"
    },
    {
      "type": "color",
      "id": "filter_bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "filter_text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "filter_border_color",
      "label": "Border",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "filter_hover_bg_color",
      "label": "Hover background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "filter_hover_text_color",
      "label": "Hover text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "filter_hover_border_color",
      "label": "Hover border",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "filter_active_bg_color",
      "label": "Active background",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "filter_active_text_color",
      "label": "Active text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "filter_active_border_color",
      "label": "Active border",
      "default": "#0f172a"
    },
    {
      "type": "range",
      "id": "filter_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 24
    },
    {
      "type": "header",
      "content": "Product cards"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Border",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 18
