    {
      "type": "text",
      "id": "target_date",
      "label": "Target date",
      "default": "2026-03-17",
      "info": "Format: YYYY-MM-DD (e.g., 2026-03-17)"
    },
    {
      "type": "text",
      "id": "target_time",
      "label": "Target time",
      "default": "23:59",
      "info": "Format: HH:MM (24-hour format, e.g., 23:59)"
    },
    {
      "type": "inline_richtext",
      "id": "expired_message",
      "label": "Expired message",
