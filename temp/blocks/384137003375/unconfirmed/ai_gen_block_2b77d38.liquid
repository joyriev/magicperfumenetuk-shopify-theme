      "default": 48
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "expired_text_size",
      "label": "Expired message size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
